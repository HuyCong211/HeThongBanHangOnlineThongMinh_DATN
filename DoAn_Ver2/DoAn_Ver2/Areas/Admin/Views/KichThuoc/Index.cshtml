@using PagedList.Mvc
@using PagedList
@model IPagedList<DoAn_Ver2.Models.KichThuoc>

@{
    ViewBag.Title = "Quản lý Kích thước";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    /* CSS Phân trang */
    .pagination-container ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
    }

    .pagination-container li {
        margin-right: 5px;
    }

        .pagination-container li a, .pagination-container li span {
            position: relative;
            display: block;
            padding: 0.5rem 0.75rem;
            margin-left: -1px;
            line-height: 1.25;
            color: #007bff;
            background-color: #fff;
            border: 1px solid #dee2e6;
            text-decoration: none;
            border-radius: 3px;
        }

    .pagination-container .active span {
        z-index: 1;
        color: #fff;
        background-color: #007bff;
        border-color: #007bff;
    }
</style>

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 font-weight-bold text-primary">DANH SÁCH KÍCH THƯỚC (Size)</h5>
        <a href="@Url.Action("Create")" class="btn btn-primary btn-sm">
            <i class="fas fa-plus"></i> Thêm size mới
        </a>
    </div>
    <div class="card-body">

        @using (Html.BeginForm("Index", "KichThuoc", FormMethod.Get, new { @class = "mb-3" }))
        {
            <div class="input-group" style="max-width: 400px;">
                <input type="text" name="searchString" value="@ViewBag.CurrentFilter"
                       class="form-control" placeholder="Nhập tên size (VD: XL, 42...)..." />
                <div class="input-group-append">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Tìm</button>
                    @if (!string.IsNullOrEmpty(ViewBag.CurrentFilter as string))
                    {
                        <a href="@Url.Action("Index")" class="btn btn-secondary" title="Reset"><i class="fas fa-sync"></i></a>
                    }
                </div>
            </div>
        }

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-@TempData["MessageType"] alert-dismissible fade show" role="alert">
                @TempData["Message"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="thead-light">
                    <tr>
                        <th class="font-weight-bold text-center" style="width: 70px;">ID</th>
                        <th class="font-weight-bold text-center">Tên Size</th>
                        <th class="font-weight-bold text-center" style="width: 250px;">Tác vụ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="font-weight-bold text-center">@item.ID</td>
                                <td class="font-weight-bold text-center" style="font-size: 1.1rem;">
                                    <span class="badge badge-secondary p-2" style="min-width: 50px;">@item.TenSize</span>
                                </td>
                                <td class="font-weight-bold text-center">
                                    <a href="@Url.Action("Edit", new { id = item.ID })" class="btn btn-info btn-sm" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.ID })" class="btn btn-danger btn-sm" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa size này không?');">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-3">
                                <i class="fas fa-box-open fa-2x mb-2"></i><br />
                                Không tìm thấy dữ liệu.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.PageCount > 1)
        {

            <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap">
                <div class="small text-muted mb-2">
                    Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) / @Model.PageCount
                    (Tổng: @Model.TotalItemCount size)
                </div>
                <div class="d-flex align-items-center mb-2">
                    <div class="mr-3">
                        @Html.PagedListPager(Model, page => Url.Action("Index", new
                        {
                            page,
                            searchString = ViewBag.CurrentFilter
                        }))
                    </div>

                    @using (Html.BeginForm("Index", "KichThuoc", FormMethod.Get, new { @class = "form-inline" }))
                    {
                        <input type="hidden" name="searchString" value="@ViewBag.CurrentFilter" />
                        <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />

                        <div class="input-group input-group-sm">
                            <input type="number" name="page" class="form-control" placeholder="Trang..."
                                   min="1" max="@Model.PageCount" style="width: 70px;" required>
                            <div class="input-group-append">
                                <button class="btn btn-primary" type="submit">Đến</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>