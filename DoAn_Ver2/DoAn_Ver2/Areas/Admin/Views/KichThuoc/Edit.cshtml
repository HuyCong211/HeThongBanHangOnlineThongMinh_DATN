@model DoAn_Ver2.Models.KichThuoc

@{
    ViewBag.Title = "Cập nhật Kích thước";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow" style="max-width: 500px; margin: 0 auto;">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Cập nhật Size</h6>
    </div>
    <div class="card-body">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.ID)

            <div class="form-group">
                <label>Tên Size <span class="text-danger">(*)</span></label>
                @Html.EditorFor(model => model.TenSize, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                @Html.ValidationMessageFor(model => model.TenSize, "", new { @class = "text-danger" })
            </div>

            <div class="form-group text-center mt-4">
                <a href="@Url.Action("Index")" class="btn btn-secondary mr-2">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
                <button type="submit" class="btn btn-success px-4">
                    <i class="fas fa-save"></i> Cập nhật
                </button>
            </div>
        }
    </div>
</div>
