        <div id="ultimate-effect-container"></div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const container = document.getElementById('ultimate-effect-container');

                // --- CẤU HÌNH CHÍNH Ở ĐÂY (CHỈ CẦN SỬA DÒNG NÀY) ---
                // Các lựa chọn: 'sakura' | 'snow' | 'autumn' | 'grades' | 'rain' | 'fireworks'
                const activeMode = '@currentEffect';

                // Nếu admin chọn 'none' thì không chạy gì cả
                if (activeMode === 'none' || !activeMode) return;


                // Cấu hình chi tiết cho từng chế độ (Có thể tùy chỉnh sâu hơn nếu muốn)
                const modesConfig = {
                    // Chế độ rơi Emoji (Hoa, Tuyết, Lá...)
                    emojiBase: {
                        quantity: 100, minSize: 15, maxSize: 25, minSpeed: 7, maxSpeed: 15,
                        isGrades: false // Mặc định không phải là điểm số
                    },
                    // Cấu hình riêng cho từng loại emoji
                    sakura: { icons: ['🌸', '🌺'], useBase: 'emojiBase' },
                    autumn: { icons: ['🍁', '🍂'], useBase: 'emojiBase' },
                    snow: {
                        icons: ['❄️', '❅', '❆'], useBase: 'emojiBase',
                        styleOverride: { color: 'white', textShadow: '0 0 5px rgba(255,255,255,0.8)' }
                    },
                    grades: {
                        icons: ['A', 'B+', 'A', 'B+'], useBase: 'emojiBase',
                        isGrades: true, // Đánh dấu là điểm số
                        styleOverride: { color: '#e74a3b', fontWeight: '900', fontFamily: 'Arial, sans-serif' } // Màu đỏ
                    },

                    // Chế độ Mưa
                    rain: {
                        quantity: 100, // Mưa cần nhiều hạt hơn
                        minSpeed: 0.8, maxSpeed: 1.5 // Mưa rơi rất nhanh
                    },

                    // Chế độ Pháo hoa
                    fireworks: {
                        frequency: 300, // Bao lâu bắn 1 quả (ms)
                        particlesPerExplosion: 100 // Số hạt mỗi quả
                    }
                };


                // --- HÀM KHỞI TẠO CHÍNH ---
                function initEffect() {
                    container.innerHTML = ''; // Xóa hiệu ứng cũ nếu có

                    if (modesConfig[activeMode]?.useBase === 'emojiBase') {
                        // Chế độ rơi Emoji (Sakura, Snow, Grades...)
                        initFallingEmojis(activeMode);
                    } else if (activeMode === 'rain') {
                        // Chế độ Mưa
                        initRain();
                    } else if (activeMode === 'fireworks') {
                        // Chế độ Pháo hoa
                        initFireworks();
                    } else {
                        console.warn('Chế độ hiệu ứng không hợp lệ:', activeMode);
                    }
                }

                // ======================================================
                // 1. XỬ LÝ CHẾ ĐỘ RƠI EMOJI & ĐIỂM SỐ
                // ======================================================
                function initFallingEmojis(modeKey) {
                    const config = { ...modesConfig.emojiBase, ...modesConfig[modeKey] };
                    const iconList = config.icons;

                    for (let i = 0; i < config.quantity; i++) {
                        const item = document.createElement('div');
                        item.classList.add('falling-emoji');

                        // Random icon từ danh sách
                        item.textContent = iconList[Math.floor(Math.random() * iconList.length)];

                        // Áp dụng style đặc biệt (nếu có - VD: tuyết trắng, điểm đỏ)
                        if (config.styleOverride) {
                            Object.assign(item.style, config.styleOverride);
                        }

                        // Random vị trí và kích thước
                        item.style.left = Math.random() * 100 + 'vw';
                        const size = Math.random() * (config.maxSize - config.minSize) + config.minSize;
                        item.style.fontSize = size + 'px';
                        item.style.opacity = (Math.random() * 0.4 + 0.6).toFixed(2);

                        // Random tốc độ
                        const duration = Math.random() * (config.maxSpeed - config.minSpeed) + config.minSpeed;
                        // Gán animation: tên | thời gian | kiểu chạy | delay | lặp lại
                        item.style.animation = `emoji-fall ${duration}s linear -${Math.random() * 5}s infinite, emoji-sway ${duration * 1.2}s ease-in-out -${Math.random() * 5}s infinite alternate`;

                        container.appendChild(item);
                    }
                }

                // ======================================================
                // 2. XỬ LÝ CHẾ ĐỘ MƯA
                // ======================================================
                function initRain() {
                    const config = modesConfig.rain;
                    for (let i = 0; i < config.quantity; i++) {
                        const drop = document.createElement('div');
                        drop.classList.add('rain-drop');

                        drop.style.left = Math.random() * 100 + 'vw';
                        // Random độ dài ngắn của hạt mưa một chút
                        drop.style.height = (Math.random() * 10 + 20) + 'px';

                        const duration = Math.random() * (config.maxSpeed - config.minSpeed) + config.minSpeed;
                        // Delay âm để mưa xuất hiện ngay lập tức khi load
                        drop.style.animation = `rain-fall ${duration}s linear -${Math.random() * 2}s infinite`;

                        container.appendChild(drop);
                    }
                }

                // ======================================================
                // 3. XỬ LÝ CHẾ ĐỘ PHÁO HOA
                // ======================================================
                function initFireworks() {
                    const config = modesConfig.fireworks;

                    // Hàm tạo màu ngẫu nhiên rực rỡ
                    function getRandomColor() {
                        const colors = ['#ff0000', '#00ff00', '#0000ff', '#ffff00', '#00ffff', '#ff00ff', '#ffba08', '#fb5607'];
                        return colors[Math.floor(Math.random() * colors.length)];
                    }

                    // Hàm bắn 1 quả pháo
                    function launchFirework() {
                        // Vị trí nổ ngẫu nhiên trên màn hình (tránh sát mép quá)
                        const startX = Math.random() * 80 + 10; // 10% -> 90% width
                        const startY = Math.random() * 60 + 10;  // 10% -> 70% height (nổ ở phía trên)
                        const color = getRandomColor();

                        for (let i = 0; i < config.particlesPerExplosion; i++) {
                            const particle = document.createElement('div');
                            particle.classList.add('firework-particle');
                            particle.style.left = startX + 'vw';
                            particle.style.top = startY + 'vh';
                            particle.style.color = color; // Màu cho box-shadow

                            // Tính toán góc và lực bắn ra xung quanh (dùng hình học)
                            const angle = (Math.random() * 360) * (Math.PI / 180); // Góc ngẫu nhiên
                            const force = Math.random() * 150 + 50; // Lực bay xa (50px - 200px)

                            // Set biến CSS để animation sử dụng
                            particle.style.setProperty('--x', Math.cos(angle) * force + 'px');
                            particle.style.setProperty('--y', Math.sin(angle) * force + 'px');

                            container.appendChild(particle);

                            // Tự hủy hạt sau khi nổ xong để nhẹ máy
                            setTimeout(() => {
                                particle.remove();
                            }, 1100);
                        }
                    }

                    // Bắn quả đầu tiên ngay lập tức
                    launchFirework();
                    // Hẹn giờ bắn các quả tiếp theo
                    setInterval(launchFirework, config.frequency);
                }

                // CHẠY ỨNG DỤNG
                initEffect();
            });
        </script>*@

    <style>
        /* 1. CẤU HÌNH CHUNG */
        #ultimate-effect-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            pointer-events: none;
            z-index: 9999;
            overflow: hidden;
            /* Nền tối nhẹ để pháo hoa nổi bật hơn nếu muốn (tuỳ chọn) */
            /* background: rgba(0,0,0,0.1); */
        }
        /* Canvas phải full màn hình */
        canvas {
            display: block;
        }

        /* CSS CHO EMOJI & MƯA (GIỮ NGUYÊN ĐỂ PHÒNG KHI ADMIN ĐỔI LẠI) */
        .falling-emoji {
            position: absolute;
            top: -50px;
            user-select: none;
            cursor: default;
            animation: emoji-fall linear infinite, emoji-sway ease-in-out infinite alternate;
            display: flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
            will-change: transform, top, opacity;
        }

        @@keyframes emoji-fall {
            0% {
                top: -10%;
                opacity: 0;
            }

            20% {
                opacity: 1;
            }

            100% {
                top: 110%;
                opacity: 0;
            }
        }

        @@keyframes emoji-sway {
            0% {
                transform: translateX(0) rotate(0deg);
            }

            100% {
                transform: translateX(35px) rotate(360deg);
            }
        }

        .rain-drop {
            position: absolute;
            width: 2px;
            height: 25px;
            background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(174, 194, 224, 0.8));
            top: -50px;
            animation: rain-fall linear infinite;
            will-change: top, opacity;
        }

        @@keyframes rain-fall {
            0% {
                top: -5%;
                opacity: 0;
            }

            10% {
                opacity: 1;
            }

            100% {
                top: 105%;
                opacity: 0.3;
            }
        }
    </style>

    <div id="ultimate-effect-container"></div>

    <script>
    document.addEventListener("DOMContentLoaded", function () {
        const container = document.getElementById('ultimate-effect-container');
        const activeMode = '@currentEffect';

        if (activeMode === 'none' || !activeMode) return;

        // CẤU HÌNH CÁC CHẾ ĐỘ CŨ
        const modesConfig = {
            emojiBase: { quantity: 80, minSize: 15, maxSize: 25, minSpeed: 7, maxSpeed: 15 },
            sakura: { icons: ['🌸', '🌺'], useBase: 'emojiBase' },
            autumn: { icons: ['🍁', '🍂'], useBase: 'emojiBase' },
            snow: { icons: ['❄️', '❅', '❆'], useBase: 'emojiBase', styleOverride: { color: 'white', textShadow: '0 0 5px rgba(255,255,255,0.8)' } },
            grades: { icons: ['A', 'B+', 'A', 'B+'], useBase: 'emojiBase', isGrades: true, styleOverride: { color: '#e74a3b', fontWeight: '900', fontFamily: 'Arial, sans-serif' } },
            rain: { quantity: 100, minSpeed: 0.8, maxSpeed: 1.5 }
        };

        // --- BỘ ĐIỀU KHIỂN CHÍNH ---
        function initEffect() {
            container.innerHTML = '';
            // Nếu chọn pháo hoa -> Chạy chế độ Canvas đặc biệt
            if (activeMode === 'fireworks') {
                initCanvasFireworksHighEnd();
            }
            // Các chế độ cũ (dùng thẻ div)
            else if (modesConfig[activeMode]?.useBase === 'emojiBase') { initFallingEmojis(activeMode); }
            else if (activeMode === 'rain') { initRain(); }
        }

        // ==================================================================================
        //  CANVAS FIREWORKS HIGH-END ENGINE (CỖ MÁY PHÁO HOA CAO CẤP)
        // ==================================================================================
        function initCanvasFireworksHighEnd() {
            const canvas = document.createElement('canvas');
            container.appendChild(canvas);
            const ctx = canvas.getContext('2d');
            let cw = window.innerWidth;
            let ch = window.innerHeight;
            canvas.width = cw; canvas.height = ch;

            window.addEventListener('resize', () => { cw = window.innerWidth; ch = window.innerHeight; canvas.width = cw; canvas.height = ch; });

            const particles = []; // Chứa các hạt pháo đang nổ
            let lastLaunchTime = 0;

            // === CẤU HÌNH PHÁO HOA TẠI ĐÂY ===
            const FW_CONFIG = {
                frequency: 1200,       // Bao lâu bắn 1 quả (ms) - Tăng lên để nổ thưa hơn, sang hơn
                particleCount: 180,    // Số hạt mỗi quả (Nhiều hạt = dày đặc)
                explodePower: 15,      // Lực nổ bung ra (Tán rộng)
                friction: 0.96,        // Ma sát không khí (Càng gần 1 càng bay xa, càng nhỏ càng nhanh dừng lại -> tạo hiệu ứng chậm)
                gravity: 0.08,         // Trọng lực kéo hạt rơi xuống
                trailLength: 0.15,     // Độ dài đuôi (0.1 = dài, 0.5 = ngắn, 1 = không đuôi) - Kỹ thuật làm mờ màn hình
                colors: ['#ff0040', '#00ffff', '#ffff00', '#ff8000', '#00ff80', '#ffffff', '#da00ff'] // Bảng màu sang trọng
            };

            function random(min, max) { return Math.random() * (max - min) + min; }

            // --- LỚP ĐỐI TƯỢNG HẠT PHÁO (PARTICLE) ---
            class Particle {
                constructor(x, y, hue) {
                    this.x = x; this.y = y;
                    // Tạo lịch sử toạ độ để vẽ đuôi
                    this.coordinates = [];
                    this.coordinateCount = 6; // Số đốt đuôi
                    while (this.coordinateCount--) { this.coordinates.push([this.x, this.y]); }

                    // Vật lý vụ nổ
                    this.angle = random(0, Math.PI * 2); // Góc ngẫu nhiên 360 độ
                    this.speed = random(1, FW_CONFIG.explodePower); // Tốc độ bay

                    // Tính toán vận tốc theo trục X, Y
                    this.vx = Math.cos(this.angle) * this.speed;
                    this.vy = Math.sin(this.angle) * this.speed;

                    // Màu sắc và độ sáng
                    this.hue = hue;
                    this.brightness = random(60, 90); // Độ sáng (lấp lánh)
                    this.alpha = 1; // Độ trong suốt bắt đầu
                    this.decay = random(0.008, 0.015); // Tốc độ mờ dần (Càng nhỏ càng lâu tắt -> nổ chậm)
                }

                update(index) {
                    // Xoá đốt đuôi cũ nhất, thêm toạ độ hiện tại vào đầu
                    this.coordinates.pop();
                    this.coordinates.unshift([this.x, this.y]);

                    // Áp dụng vật lý
                    this.vx *= FW_CONFIG.friction; // Chậm dần do ma sát
                    this.vy *= FW_CONFIG.friction;
                    this.vy += FW_CONFIG.gravity; // Rơi xuống do trọng lực
                    this.x += this.vx;
                    this.y += this.vy;

                    // Mờ dần
                    this.alpha -= this.decay;
                    // Nếu mờ hết thì xoá khỏi mảng
                    if (this.alpha <= 0) { particles.splice(index, 1); }
                }

                draw() {
                    ctx.beginPath();
                    // Vẽ đường nối từ đốt đuôi cuối cùng đến vị trí hiện tại
                    ctx.moveTo(this.coordinates[this.coordinates.length - 1][0], this.coordinates[this.coordinates.length - 1][1]);
                    ctx.lineTo(this.x, this.y);
                    // Màu HSL: Hue, Saturation, Lightness, Alpha
                    ctx.strokeStyle = `hsla(${this.hue}, 100%, ${this.brightness}%, ${this.alpha})`;
                    ctx.lineWidth = 2; // Độ dày đuôi
                    ctx.lineCap = 'round'; // Đầu cọ tròn
                    ctx.stroke();
                }
            }

            // --- HÀM TẠO VỤ NỔ ---
            function explode(x, y) {
                let count = FW_CONFIG.particleCount;
                // Chọn màu chủ đạo cho quả pháo này
                const baseColorHex = FW_CONFIG.colors[Math.floor(random(0, FW_CONFIG.colors.length))];
                // Chuyển đổi màu hex sang HSL hue (ước lượng để tạo dải màu tương đồng)
                let baseHue = 0;
                if (baseColorHex === '#ff0040') baseHue = 345;
                else if (baseColorHex === '#00ffff') baseHue = 180;
                else if (baseColorHex === '#ffff00') baseHue = 60;
                else if (baseColorHex === '#da00ff') baseHue = 280;
                else baseHue = random(0, 360);

                while (count--) {
                    // Tạo các hạt với màu sắc biến thiên nhẹ quanh màu chủ đạo cho tự nhiên
                    particles.push(new Particle(x, y, random(baseHue - 20, baseHue + 20)));
                }
            }

            // --- VÒNG LẶP HOẠT HÌNH CHÍNH (GAME LOOP) ---
            function animate(currentTime) {
                requestAnimationFrame(animate);

                // KỸ THUẬT TẠO ĐUÔI: Thay vì xoá trắng màn hình, ta phủ lên một lớp màu đen bán trong suốt.
                // Điều này làm cho frame cũ mờ đi từ từ, tạo ra hiệu ứng vệt sáng kéo dài.
                ctx.globalCompositeOperation = 'destination-out';
                ctx.fillStyle = `rgba(0, 0, 0, ${FW_CONFIG.trailLength})`;
                ctx.fillRect(0, 0, cw, ch);

                // KỸ THUẬT PHÁT SÁNG: 'lighter' làm cho các pixel chồng lên nhau sáng rực lên.
                ctx.globalCompositeOperation = 'lighter';

                // Cập nhật và vẽ tất cả các hạt
                let i = particles.length;
                while (i--) {
                    particles[i].draw();
                    particles[i].update(i);
                }

                // Tự động bắn pháo theo thời gian
                if (currentTime - lastLaunchTime > FW_CONFIG.frequency) {
                    // Nổ ở vị trí ngẫu nhiên trong vùng an toàn của màn hình (tránh sát mép)
                    explode(random(cw * 0.1, cw * 0.9), random(ch * 0.1, ch * 0.8));
                    lastLaunchTime = currentTime;
                }
            }

            // Bắt đầu vòng lặp
            animate();
        }


        // --- CÁC HÀM CŨ (GIỮ LẠI ĐỂ KHÔNG LỖI KHI CHỌN HIỆU ỨNG KHÁC) ---
        function initFallingEmojis(modeKey) {
            const config = { ...modesConfig.emojiBase, ...modesConfig[modeKey] }; const iconList = config.icons;
            for (let i = 0; i < config.quantity; i++) {
                const item = document.createElement('div'); item.classList.add('falling-emoji');
                item.textContent = iconList[Math.floor(Math.random() * iconList.length)];
                if (config.styleOverride) Object.assign(item.style, config.styleOverride);
                item.style.left = Math.random() * 100 + 'vw'; item.style.fontSize = Math.random() * (config.maxSize - config.minSize) + config.minSize + 'px';
                item.style.opacity = (Math.random() * 0.4 + 0.6).toFixed(2); item.style.animationDuration = Math.random() * (config.maxSpeed - config.minSpeed) + config.minSpeed + 's';
                container.appendChild(item);
            }
        }
        function initRain() {
            const config = modesConfig.rain;
            for (let i = 0; i < config.quantity; i++) {
                const drop = document.createElement('div'); drop.classList.add('rain-drop');
                drop.style.left = Math.random() * 100 + 'vw'; drop.style.height = (Math.random() * 10 + 20) + 'px';
                drop.style.animationDuration = Math.random() * (config.maxSpeed - config.minSpeed) + config.minSpeed + 's';
                container.appendChild(drop);
            }
        }

        initEffect();
    });
    </script>

