@using DoAn_Ver2.Models
@using DoAn_Ver2.Infrastructure

@{

    // --- CẤU HÌNH PHIÊN BẢN HỆ THỐNG ---
    string appVersion = "1.0.0 Beta";

    // 1. LẤY THÔNG TIN NGƯỜI DÙNG TỪ SESSION
    var user = Session["UserAdmin"] as NguoiDung;
    string tenHienThi = "Khách";
    string avtUrl = "https://ui-avatars.com/api/?name=Guest&background=random";
    string vaiTro = "";
    int userId = 0;
    string currentEffect = "none";

    if (user != null)
    {
        // Ưu tiên hiển thị Họ tên, nếu không có thì hiện Tên đăng nhập
        tenHienThi = !string.IsNullOrEmpty(user.HoTen) ? user.HoTen : user.TenDangNhap;

        // Nếu có Avatar thì dùng, không thì dùng Avatar tạo tự động theo tên
        avtUrl = !string.IsNullOrEmpty(user.Avt) ? user.Avt : $"https://ui-avatars.com/api/?name={tenHienThi}&background=4e73df&color=fff";

        vaiTro = user.VaiTro; // Admin hoặc Staff
        userId = user.ID;
    }
    string siteLogo = "/Content/images/logo-default.png"; 
    try
    {
        using (var uow = new UnitOfWork())
        {
            var config = uow.Repository<CauHinhChung>().GetById("SiteLogo");
            if (config != null && !string.IsNullOrEmpty(config.Value))
            {
                siteLogo = config.Value;
            }
            var effConfig = uow.Repository<CauHinhChung>().GetById("SiteEffect");
            if (effConfig != null) { currentEffect = effConfig.Value; }
        }
    }
    catch {  }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Hệ thống Quản trị</title>

    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@200;300;400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    <style>
        body {
            font-family: 'Nunito', sans-serif;
            background-color: #f8f9fc;
            font-size: 1rem;
            color: #5a5c69;
        }

        /* --- SIDEBAR --- */
        .sidebar {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 100;
            padding: 0;
            background: linear-gradient(180deg, #34495e 0%, #1b2836 100%);
            box-shadow: 0 0.15rem 1.75rem 0 rgba(0, 0, 0, 0.2);
        }

        .sidebar-sticky {
            position: relative;
            top: 0;
            height: 100vh;
            padding-top: 0;
            overflow-x: hidden;
            overflow-y: auto;
        }

        .sidebar-brand {
            height: 4.375rem;
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: 800;
            padding: 1.5rem 1rem;
            text-align: left;
            text-transform: uppercase;
            letter-spacing: 0.05rem;
            z-index: 1;
            color: #fff !important;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            background-color: rgba(0, 0, 0, 0.1);
        }
        .sidebar-brand-icon {
            margin-right: 15px;
        }
        .sidebar-brand-icon i {
            transform: rotate(-15deg);
        }

        .sidebar .nav-link {
            font-weight: 600;
            color: rgba(255, 255, 255, 0.8);
            padding: 1rem;
            display: block;
            width: 100%;
            text-align: left;
            transition: all 0.3s;
        }

            .sidebar .nav-link i {
                margin-right: 0.75rem;
                width: 20px;
                text-align: center;
                font-size: 0.9rem;
                color: rgba(255, 255, 255, 0.7);
            }

            .sidebar .nav-link:hover, .sidebar .nav-link.active {
                color: #fff;
                background-color: rgba(255, 255, 255, 0.15);
                font-weight: 700;
            }

                .sidebar .nav-link:hover i, .sidebar .nav-link.active i {
                    color: #fff;
                }

        .sidebar-heading {
            color: rgba(255, 255, 255, 0.4);
            font-size: 0.7rem;
            text-transform: uppercase;
            font-weight: 800;
            padding: 1.5rem 1rem 0.5rem;
            letter-spacing: 0.05em;
        }

        .sidebar-divider {
            margin: 0 1rem 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.15);
        }

        main {
            padding: 0;
            background-color: #f8f9fc;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            height: 4.375rem;
            background-color: #fff !important;
            box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,.15);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 2rem;
            flex-shrink: 0;
        }

        .page-content {
            padding: 0 1.5rem;
            flex: 1;
        }

        .dropdown-item {
            font-size: 0.9rem;
            padding: 0.5rem 1.5rem;
        }

            .dropdown-item:hover {
                background-color: #f8f9fc;
            }

            .dropdown-item i {
                margin-right: 0.5rem;
                color: #d1d3e2;
            }


        /* --- FOOTER (MÀU XÁM BẠC) --- */
        .sticky-footer {
            background-color: #eaecf4; /* MÀU MỚI: Xám bạc */
            padding: 0.8rem 0;
            margin-top: 2rem;
            border-top: 1px solid #d1d3e2; /* Viền đậm hơn chút để rõ nét */
            font-size: 0.85rem;
            color: #6e707e; /* Màu chữ đậm hơn chút cho dễ đọc trên nền xám */
            flex-shrink: 0;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .heart-icon {
            color: #e74a3b;
            font-size: 0.9rem;
            animation: beat .8s infinite alternate;
        }

        .ver-tag {
            background: #fff; /* Tag màu trắng cho nổi trên nền xám */
            padding: 2px 8px;
            border-radius: 4px;
            font-weight: 700;
            color: #4e73df;
            font-size: 0.75rem;
            border: 1px solid #d1d3e2;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }

        /* Hiệu ứng trái tim đập */
        @@keyframes beat {
            to {
                transform: scale(1.2);
            }
        }

        @@media (max-width: 768px) {
            .footer-content {
                flex-direction: column;
                text-align: center;
            }

                .footer-content > div {
                    margin-bottom: 5px;
                }
        }

    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="sidebar-sticky">
                    <a class="sidebar-brand" href="@Url.Action("Index", "Dashboard")">
                        <div class="sidebar-brand-icon">
                            <img src="@siteLogo" alt="Logo"
                                 style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; background-color: #fff; border: 2px solid #eaecf4;">
                        </div>
                        <div class="sidebar-brand-text">MEN STORE</div>
                    </a>

                    <ul class="nav flex-column mt-3">

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Dashboard" ? "active" : "")"
                               href="@Url.Action("Index", "Dashboard")">
                                <i class="fas fa-fw fa-tachometer-alt"></i>
                                <span>Tổng quan</span>
                            </a>
                        </li>

                        <hr class="sidebar-divider my-2">

                        <div class="sidebar-heading">Sản phẩm & Kho</div>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "DanhMuc" ? "active" : "")"
                               href="@Url.Action("Index", "DanhMuc")">
                                <i class="fas fa-fw fa-list"></i>
                                <span>Danh mục</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "SanPham" ? "active" : "")"
                               href="@Url.Action("Index", "SanPham")">
                                <i class="fas fa-fw fa-tshirt"></i>
                                <span>Sản phẩm</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "MauSac" ? "active" : "")"
                               href="@Url.Action("Index", "MauSac")">
                                <i class="fas fa-fw fa-palette"></i>
                                <span>Màu sắc</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "KichThuoc" ? "active" : "")"
                               href="@Url.Action("Index", "KichThuoc")">
                                <i class="fas fa-fw fa-ruler-combined"></i>
                                <span>Kích thước</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Kho" ? "active" : "")"
                               href="@Url.Action("Index", "Kho")">
                                <i class="fas fa-fw fa-warehouse"></i>
                                <span>Quản lý Kho (SKU)</span>
                            </a>
                        </li>

                        <hr class="sidebar-divider">

                        <div class="sidebar-heading">Kinh doanh</div>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "DonHang" ? "active" : "")"
                               href="@Url.Action("Index", "DonHang")">
                                <i class="fas fa-fw fa-shopping-cart"></i>
                                <span>Đơn hàng</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "News" ? "active" : "")"
                               href="@Url.Action("Index", "News")">
                                <i class="fas fa-fw fa-newspaper"></i>
                                <span>Tin tức (Blog)</span>
                            </a>
                        </li>

                        @if (vaiTro == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Marketing" ? "active" : "")"
                                   href="@Url.Action("Index", "Marketing")">
                                    <i class="fas fa-fw fa-tags"></i>
                                    <span>Mã giảm giá (Voucher)</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Report" ? "active" : "")"
                                   href="@Url.Action("Index", "Report")">
                                    <i class="fas fa-fw fa-chart-line"></i>
                                    <span>Báo cáo & Thống kê</span>
                                </a>
                            </li>

                            <hr class="sidebar-divider">
                            <div class="sidebar-heading">Hệ thống (Admin)</div>

                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "User" ? "active" : "")"
                                   href="@Url.Action("Index", "User")">
                                    <i class="fas fa-fw fa-users"></i>
                                    <span>Người dùng</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Payment" ? "active" : "")"
                                   href="@Url.Action("Index", "Payment")">
                                    <i class="fas fa-fw fa-money-check-alt"></i>
                                    <span>Thanh toán</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Review", new { area = "Admin" })">
                                    <i class="fas fa-fw fa-star"></i>
                                    <span>Quản lý Đánh giá</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Config" ? "active" : "")"
                                   href="@Url.Action("Index", "Config")">
                                    <i class="fas fa-fw fa-cogs"></i>
                                    <span>Cấu hình chung</span>
                                </a>
                            </li>
                        }

                        <li class="nav-item mt-3">
                            <a class="nav-link text-warning font-weight-bold" href="@Url.Action("Logout", "Auth")">
                                <i class="fas fa-sign-out-alt text-warning"></i>
                                <span>Đăng xuất</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <main role="main" class="col-md-9 ml-sm-auto col-lg-10 px-md-0">

                <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow">
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars"></i>
                    </button>

                    <ul class="navbar-nav ml-auto">
                        <div class="topbar-divider d-none d-sm-block"></div>

                        <li class="nav-item dropdown no-arrow">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <span class="mr-2 d-none d-lg-inline text-gray-600 small">
                                    Xin chào, <b>@tenHienThi</b>
                                </span>
                                <img class="img-profile rounded-circle" src="@avtUrl" style="height: 2rem; width: 2rem; object-fit: cover;">
                            </a>

                            <div class="dropdown-menu dropdown-menu-right shadow animated--grow-in" aria-labelledby="userDropdown">
                                <a class="dropdown-item" href="@Url.Action("Index", "Profile")">
                                    <i class="fas fa-user fa-sm fa-fw mr-2 text-gray-400"></i>
                                    Hồ sơ cá nhân
                                </a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="@Url.Action("Logout", "Auth")">
                                    <i class="fas fa-sign-out-alt fa-sm fa-fw mr-2 text-gray-400"></i>
                                    Đăng xuất
                                </a>
                            </div>
                        </li>
                    </ul>
                </nav>

                <div class="page-content">
                    @RenderBody()
                </div>

                <footer class="sticky-footer">
                    <div class="container-fluid px-4">
                        <div class="footer-content">
                            <div>
                                <span class="mr-1">Copyright &copy; @DateTime.Now.Year <b>MEN STORE Management System</b>.</span>
                                <span>Đồ án tốt nghiệp - Thực hiện bởi <b class="text-dark">Nguyễn Huy Công</b></span>
                                <i class="fas fa-heart heart-icon mx-1" title="Made with Love"></i>
                            </div>

                            <div>
                                <span class="ver-tag">Ver @appVersion</span>
                            </div>
                        </div>
                    </div>
                </footer>

            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
    @RenderSection("scripts", required: false)


    @*================================================
        HIỆU ỨNG RƠI (Hoa, Tuyết, Điểm) + MƯA + PHÁO HOA
        ================================================*@

    <link href="~/Content/StyleHieuUng.css" rel="stylesheet" />
    <div id="ultimate-effect-container"></div>
    <script src="~/Scripts/HieuUng.js"></script>
    

</body>
</html>