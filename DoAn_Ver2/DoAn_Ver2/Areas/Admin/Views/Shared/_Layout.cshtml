@using DoAn_Ver2.Models
@using DoAn_Ver2.Infrastructure

@{

    // --- CẤU HÌNH PHIÊN BẢN HỆ THỐNG ---
    string appVersion = "1.0.0 Beta";

    // 1. LẤY THÔNG TIN NGƯỜI DÙNG TỪ SESSION
    var user = Session["UserAdmin"] as NguoiDung;
    string tenHienThi = "Khách";
    string avtUrl = "https://ui-avatars.com/api/?name=Guest&background=random";
    string vaiTro = "";
    int userId = 0;
    string currentEffect = "none";

    if (user != null)
    {
        // Ưu tiên hiển thị Họ tên, nếu không có thì hiện Tên đăng nhập
        tenHienThi = !string.IsNullOrEmpty(user.HoTen) ? user.HoTen : user.TenDangNhap;

        // Nếu có Avatar thì dùng, không thì dùng Avatar tạo tự động theo tên
        avtUrl = !string.IsNullOrEmpty(user.Avt) ? user.Avt : $"https://ui-avatars.com/api/?name={tenHienThi}&background=4e73df&color=fff";

        vaiTro = user.VaiTro; // Admin hoặc Staff
        userId = user.ID;
    }

    // 2. [MỚI] LẤY LOGO TỪ CẤU HÌNH CHUNG
    // Khởi tạo UnitOfWork để truy vấn DB ngay tại View (hoặc dùng ViewBag từ Controller Base nếu có)
    string siteLogo = "/Content/images/logo-default.png"; // Ảnh mặc định nếu chưa cấu hình
    try
    {
        using (var uow = new UnitOfWork())
        {
            var config = uow.Repository<CauHinhChung>().GetById("SiteLogo");
            if (config != null && !string.IsNullOrEmpty(config.Value))
            {
                siteLogo = config.Value;
            }
            var effConfig = uow.Repository<CauHinhChung>().GetById("SiteEffect");
            if (effConfig != null) { currentEffect = effConfig.Value; }
        }
    }
    catch { /* Bỏ qua lỗi nếu DB chưa sẵn sàng */ }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Hệ thống Quản trị</title>

    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@200;300;400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    <style>
        body {
            font-family: 'Nunito', sans-serif;
            background-color: #f8f9fc;
            font-size: 1rem;
            color: #5a5c69;
        }

        /* --- SIDEBAR --- */
        .sidebar {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 100;
            padding: 0;
            background: linear-gradient(180deg, #34495e 0%, #1b2836 100%);
            box-shadow: 0 0.15rem 1.75rem 0 rgba(0, 0, 0, 0.2);
        }

        .sidebar-sticky {
            position: relative;
            top: 0;
            height: 100vh;
            padding-top: 0;
            overflow-x: hidden;
            overflow-y: auto;
        }

        .sidebar-brand {
            height: 4.375rem;
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: 800;
            padding: 1.5rem 1rem;
            text-align: left;
            text-transform: uppercase;
            letter-spacing: 0.05rem;
            z-index: 1;
            color: #fff !important;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            background-color: rgba(0, 0, 0, 0.1);
        }
        /* Thêm class này hoặc sửa nếu đã có để tạo khoảng cách */
        .sidebar-brand-icon {
            margin-right: 15px; /* QUAN TRỌNG: Cách chữ ra 15px (bạn có thể tăng giảm số này) */
        }
        .sidebar-brand-icon i {
            transform: rotate(-15deg);
        }

        .sidebar .nav-link {
            font-weight: 600;
            color: rgba(255, 255, 255, 0.8);
            padding: 1rem;
            display: block;
            width: 100%;
            text-align: left;
            transition: all 0.3s;
        }

            .sidebar .nav-link i {
                margin-right: 0.75rem;
                width: 20px;
                text-align: center;
                font-size: 0.9rem;
                color: rgba(255, 255, 255, 0.7);
            }

            .sidebar .nav-link:hover, .sidebar .nav-link.active {
                color: #fff;
                background-color: rgba(255, 255, 255, 0.15);
                font-weight: 700;
            }

                .sidebar .nav-link:hover i, .sidebar .nav-link.active i {
                    color: #fff;
                }

        .sidebar-heading {
            color: rgba(255, 255, 255, 0.4);
            font-size: 0.7rem;
            text-transform: uppercase;
            font-weight: 800;
            padding: 1.5rem 1rem 0.5rem;
            letter-spacing: 0.05em;
        }

        .sidebar-divider {
            margin: 0 1rem 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.15);
        }

        /* --- CONTENT --- */
        main {
            padding: 0;
            background-color: #f8f9fc;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            height: 4.375rem;
            background-color: #fff !important;
            box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,.15);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 2rem;
            flex-shrink: 0;
        }

        .page-content {
            padding: 0 1.5rem;
            flex: 1;
        }

        /* Dropdown User */
        .dropdown-item {
            font-size: 0.9rem;
            padding: 0.5rem 1.5rem;
        }

            .dropdown-item:hover {
                background-color: #f8f9fc;
            }

            .dropdown-item i {
                margin-right: 0.5rem;
                color: #d1d3e2;
            }


        /* --- FOOTER MỚI (MÀU XÁM BẠC) --- */
        .sticky-footer {
            background-color: #eaecf4; /* MÀU MỚI: Xám bạc (tương phản nhẹ với nền trắng) */
            padding: 0.8rem 0;
            margin-top: 2rem;
            border-top: 1px solid #d1d3e2; /* Viền đậm hơn chút để rõ nét */
            font-size: 0.85rem;
            color: #6e707e; /* Màu chữ đậm hơn chút cho dễ đọc trên nền xám */
            /* Ngăn footer bị co lại */
            flex-shrink: 0;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .heart-icon {
            color: #e74a3b;
            font-size: 0.9rem;
            animation: beat .8s infinite alternate;
        }

        .ver-tag {
            background: #fff; /* Tag màu trắng cho nổi trên nền xám */
            padding: 2px 8px;
            border-radius: 4px;
            font-weight: 700;
            color: #4e73df;
            font-size: 0.75rem;
            border: 1px solid #d1d3e2;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }

        /* Hiệu ứng trái tim đập */
        @@keyframes beat {
            to {
                transform: scale(1.2);
            }
        }

        @@media (max-width: 768px) {
            .footer-content {
                flex-direction: column;
                text-align: center;
            }

                .footer-content > div {
                    margin-bottom: 5px;
                }
        }

    </style>
</head>
