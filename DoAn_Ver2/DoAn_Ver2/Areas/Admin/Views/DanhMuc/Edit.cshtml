@model DoAn_Ver2.Models.DanhMuc

@{
    ViewBag.Title = "Cập nhật Danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<style>
    .select2-container .select2-selection--single {
        height: 38px !important;
        border: 1px solid #ced4da;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 36px !important;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 36px !important;
    }
</style>

<div class="card shadow">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Cập nhật danh mục: @Model.TenDanhMuc</h6>
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Edit", "DanhMuc", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.ID)
            @Html.HiddenFor(model => model.HinhAnh)

            <div class="form-row">
                <div class="form-group col-md-6">
                    <label>Tên danh mục <span class="text-danger">(*)</span></label>
                    @Html.EditorFor(model => model.TenDanhMuc, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                    @Html.ValidationMessageFor(model => model.TenDanhMuc, "", new { @class = "text-danger" })
                </div>

            </div>

            <div class="form-group">
                <label>Danh mục cha (Tìm kiếm & chọn)</label>

                @Html.DropDownListFor(model => model.DanhMucChaID, (SelectList)ViewBag.ListDanhMuc, "--- Là danh mục gốc (Không có cha) ---", new { @class = "form-control select2-search" })

                <small class="text-muted">Gõ tên danh mục để tìm kiếm nhanh.</small>
            </div>

            <div class="form-group">
                <label>Mô tả</label>
                @Html.TextAreaFor(model => model.MoTa, new { @class = "form-control", rows = 3 })
            </div>

            <div class="form-group">
                <label>Hình ảnh đại diện</label>
                <div class="custom-file mb-3">
                    <input type="file" name="ImageFile" id="ImageFile" class="custom-file-input" accept="image/*">
                    <label class="custom-file-label" for="ImageFile">Chọn ảnh mới (nếu muốn thay đổi)...</label>
                </div>
                @Html.ValidationMessageFor(model => model.HinhAnh, "", new { @class = "text-danger" })

                <div class="border rounded p-2 text-center" style="width: 200px; min-height: 150px; background: #f8f9fa;">
                    <img id="showImage"
                         src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "" : Model.HinhAnh)"
                         alt="Preview"
                         style="max-width: 100%; @(string.IsNullOrEmpty(Model.HinhAnh) ? "display:none" : "")" />

                    <span id="noImageText" class="text-muted small" style="@(!string.IsNullOrEmpty(Model.HinhAnh) ? "display:none" : "")">
                        Hiện chưa có ảnh
                    </span>
                </div>
            </div>
            <div class="form-group col-md-2">
                @Html.LabelFor(model => model.TrangThai, "Trạng thái", new { @class = "control-label font-weight-bold" })
                @Html.DropDownListFor(model => model.TrangThai, new List<SelectListItem> {
                    new SelectListItem { Text = "Hiển thị", Value = "1" },
                    new SelectListItem { Text = "Tạm ẩn", Value = "0" }
                }, new { @class = "form-control" })
            </div>

            <div class="form-group text-left">
                <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
                <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Cập nhật</button>
            </div>
        }
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.select2-search').select2({
                placeholder: "Chọn danh mục cha...",
                allowClear: true,
                width: '100%'
            });

            $('#ImageFile').change(function (e) {
                var fileName = e.target.files[0].name;
                $('.custom-file-label').html(fileName);

                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#showImage').attr('src', e.target.result).show();
                    $('#noImageText').hide();
                }
                if (this.files && this.files[0]) {
                    reader.readAsDataURL(this.files[0]);
                }
            });
        });
    </script>
}