@model DoAn_Ver2.Models.DanhMuc

@{
    ViewBag.Title = "Thêm mới Danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<style>
    /* Fix chiều cao Select2 khớp Bootstrap */
    .select2-container .select2-selection--single {
        height: 38px !important;
        border: 1px solid #ced4da;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 36px !important;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 36px !important;
    }
</style>

<div class="card shadow">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Thêm danh mục mới</h6>
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Create", "DanhMuc", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            <div class="form-row">
                <div class="form-group col-md-6">
                    <label>Tên danh mục <span class="text-danger">(*)</span></label>
                    @Html.EditorFor(model => model.TenDanhMuc, new { htmlAttributes = new { @class = "form-control", placeholder = "Nhập tên danh mục..." } })
                    @Html.ValidationMessageFor(model => model.TenDanhMuc, "", new { @class = "text-danger" })
                </div>

                @*<div class="form-group col-md-6">
                        <label>Slug (URL)</label>
                        @Html.EditorFor(model => model.Slug, new { htmlAttributes = new { @class = "form-control", placeholder = "Để trống sẽ tự tạo theo tên" } })
                    </div>*@
            </div>

            <div class="form-group">
                <label>Danh mục cha (Tìm kiếm & chọn)</label>

                @* SỬA LẠI TÊN ViewBag Ở ĐÂY THÀNH ListDanhMuc *@
                @Html.DropDownListFor(model => model.DanhMucChaID, (SelectList)ViewBag.ListDanhMuc, "--- Là danh mục gốc (Không có cha) ---", new { @class = "form-control select2-search" })

                <small class="text-muted">Gõ tên danh mục để tìm kiếm nhanh.</small>
            </div>

            <div class="form-group">
                <label>Mô tả</label>
                @Html.TextAreaFor(model => model.MoTa, new { @class = "form-control", rows = 3 })
            </div>

            <div class="form-group">
                <label>Hình ảnh đại diện</label>
                <div class="custom-file mb-3">
                    <input type="file" name="ImageFile" id="ImageFile" class="custom-file-input" accept="image/*">
                    <label class="custom-file-label" for="ImageFile">Chọn file ảnh...</label>
                </div>
                @Html.ValidationMessageFor(model => model.HinhAnh, "", new { @class = "text-danger" })

                <div class="border rounded p-2 text-center" style="width: 200px; min-height: 150px; background: #f8f9fa;">
                    <img id="showImage" src="#" alt="Preview" style="max-width: 100%; display: none;" />
                    <span id="noImageText" class="text-muted small">Chưa chọn ảnh</span>
                </div>
            </div>

            <div class="form-group text-left">
                <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
                <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Lưu dữ liệu</button>
            </div>
        }
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            // 1. Kích hoạt Select2 tìm kiếm
            $('.select2-search').select2({
                placeholder: "Chọn danh mục cha...",
                allowClear: true,
                width: '100%'
            });

            // 2. Preview ảnh và cập nhật tên file input
            $('#ImageFile').change(function (e) {
                // Hiện tên file
                var fileName = e.target.files[0].name;
                $('.custom-file-label').html(fileName);

                // Hiện ảnh preview
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#showImage').attr('src', e.target.result).show();
                    $('#noImageText').hide();
                }
                if (this.files && this.files[0]) {
                    reader.readAsDataURL(this.files[0]);
                }
            });
        });
    </script>
}