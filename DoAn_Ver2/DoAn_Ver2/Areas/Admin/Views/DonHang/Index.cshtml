@using PagedList.Mvc
@model PagedList.IPagedList<DoAn_Ver2.Models.DonHang>

@{
    ViewBag.Title = "Quản lý Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách Đơn hàng</h6>
    </div>
    <div class="card-body">

        <form action="@Url.Action("Index")" method="get" class="mb-4">
            <div class="form-row align-items-center">

                <div class="col-auto">
                    <div class="input-group mb-2">
                        <div class="input-group-prepend">
                            <div class="input-group-text bg-primary text-white border-0"><i class="fas fa-search"></i></div>
                        </div>
                        <input type="text" name="searchString" value="@ViewBag.CurrentFilter" class="form-control" placeholder="Mã đơn / Tên khách...">
                    </div>
                </div>

                <div class="col-auto">
                    <select name="trangThai" class="form-control mb-2">
                        <option value="">-- Trạng thái --</option>
                        <option value="0" @(ViewBag.CurrentStatus == 0 ? "selected" : "")>Chờ xác nhận</option>
                        <option value="1" @(ViewBag.CurrentStatus == 1 ? "selected" : "")>Đã xác nhận</option>
                        <option value="2" @(ViewBag.CurrentStatus == 2 ? "selected" : "")>Đang giao</option>
                        <option value="3" @(ViewBag.CurrentStatus == 3 ? "selected" : "")>Hoàn thành</option>
                        <option value="4" @(ViewBag.CurrentStatus == 4 ? "selected" : "")>Đã hủy</option>
                    </select>
                </div>

                <div class="col-auto">
                    <div class="input-group mb-2">
                        <div class="input-group-prepend">
                            <span class="input-group-text">Từ</span>
                        </div>
                        <input type="date" name="fromDate" value="@ViewBag.CurrentFromDate" class="form-control">
                    </div>
                </div>

                <div class="col-auto">
                    <div class="input-group mb-2">
                        <div class="input-group-prepend">
                            <span class="input-group-text">Đến</span>
                        </div>
                        <input type="date" name="toDate" value="@ViewBag.CurrentToDate" class="form-control">
                    </div>
                </div>

                <div class="col-auto">
                    <button class="btn btn-primary mb-2 font-weight-bold" type="submit">Lọc dữ liệu</button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary mb-2 ml-1">Reset</a>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="thead-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Tác vụ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="font-weight-bold text-primary">#@item.MaDonHang</td>
                                <td>
                                    <strong>@item.TenNguoiNhan</strong><br />
                                    <small class="text-muted"><i class="fas fa-phone mr-1"></i>@item.SDT_NguoiNhan</small>
                                </td>
                                <td>@item.NgayDat.Value.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-danger font-weight-bold">
                                    @(item.TongThanhToan.HasValue ? item.TongThanhToan.Value.ToString("N0") : "0") đ
                                </td>
                                <td class="text-center">
                                    @switch (item.TrangThaiDonHang)
                                    {
                                        case 0:<span class="badge badge-secondary">Chờ xác nhận</span>; break;
                                        case 1: <span class="badge badge-info">Đã xác nhận</span>; break;
                                        case 2: <span class="badge badge-warning">Đang giao</span>; break;
                                        case 3: <span class="badge badge-success">Hoàn thành</span>; break;
                                        case 4: <span class="badge badge-danger">Đã hủy</span>; break;
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Details", new { id = item.ID })" class="btn btn-primary btn-sm shadow-sm">
                                        <i class="fas fa-eye"></i> Xem
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted font-italic py-5">
                                <i class="fas fa-box-open fa-3x mb-3"></i><br>
                                Không tìm thấy đơn hàng nào phù hợp với bộ lọc.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-3">
            <div class="col-md-6 align-self-center">
                <p class="text-muted mb-0">
                    Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) / @Model.PageCount
                    <small>(Tổng: @Model.TotalItemCount đơn)</small>
                </p>
            </div>
            <div class="col-md-6">
                <div class="float-right">
                    @Html.PagedListPager(Model, page => Url.Action("Index",
                        new
                             {
                            page,
                            searchString = ViewBag.CurrentFilter,
                            trangThai = ViewBag.CurrentStatus,
                            fromDate = ViewBag.CurrentFromDate, 
                            toDate = ViewBag.CurrentToDate      
                        }),
                        new PagedListRenderOptions
                        {
                            LiElementClasses = new string[] { "page-item" },
                            LinkToPreviousPageFormat = "«",
                            LinkToNextPageFormat = "»",
                            ClassToApplyToFirstListItemInPager = "page-item",
                            ClassToApplyToLastListItemInPager = "page-item",
                            ContainerDivClasses = new[] { "pagination-container" },
                            UlElementClasses = new[] { "pagination shadow-sm" },
                            FunctionToTransformEachPageLink = (li, a) => { a.AddCssClass("page-link"); return a; }
                        })
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .pagination {
        justify-content: flex-end;
        margin-bottom: 0;
    }
   
    .form-control:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25);
    }
</style>