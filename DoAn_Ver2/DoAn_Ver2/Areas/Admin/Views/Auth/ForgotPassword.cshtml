@{
    Layout = null;
    string bgLogin = DoAn_Ver2.Common.ConfigHelper.Get("BannerLogin");
    if (string.IsNullOrEmpty(bgLogin)) { bgLogin = "/Content/images/config/bg-login.jpg"; }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Quên mật khẩu - Men Store Admin</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Nunito', sans-serif;
            height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: url('@bgLogin') no-repeat center center fixed;
            background-size: cover;
            position: relative;
            overflow: hidden;
        }

        body::before {
            content: ""; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.1); z-index: 0;
        }
       
        @@keyframes slideDown {
            from { opacity: 0; transform: translateY(-50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes shake {
            0% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            50% { transform: translateX(10px); }
            75% { transform: translateX(-10px); }
            100% { transform: translateX(0); }
        }

        .shake-animation { animation: shake 0.4s ease-in-out; }
        .login-card {
            position: relative; z-index: 1; width: 100%; max-width: 450px; padding: 40px 30px;
            border-radius: 15px;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            box-shadow: 0 15px 25px rgba(0,0,0,0.3);
            color: #fff; text-align: center;
            animation: slideDown 0.8s ease-out forwards;
        }

        .login-header h2 { font-weight: 700; font-size: 24px; margin-bottom: 5px; }
        .login-header p { font-size: 14px; opacity: 0.8; margin-bottom: 25px; line-height: 1.6; }
        .login-icon { font-size: 50px; margin-bottom: 15px; opacity: 0.9; }
        .form-group { position: relative; margin-bottom: 25px; text-align: left; }

        .form-control-custom {
            width: 100%; padding: 12px 20px 12px 45px;
            border: 2px solid transparent; border-radius: 30px;
            font-size: 14px; outline: none; background: #fff; color: #333; transition: all 0.3s;
        }
        .form-control-custom:focus { box-shadow: 0 0 10px rgba(255,255,255,0.5); }
        .form-control-custom.is-invalid { border-color: #ff6b6b; background-color: #fff0f0; }

        .invalid-feedback-custom {
            color: #ff6b6b; font-size: 12px; font-weight: bold;
            margin-top: 5px; margin-left: 20px; display: none;
        }

        .input-icon {
            position: absolute; left: 15px; top: 22px; transform: translateY(-50%);
            color: #666; font-size: 16px;
        }
        .btn-login {
            width: 100%; padding: 12px; border-radius: 30px; border: none;
            background: linear-gradient(to right, #0f2027, #203a43, #2c5364);
            color: #fff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;
            cursor: pointer; transition: all 0.3s; margin-top: 5px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.3); color: #fff; }
        .back-link {
            display: inline-block; margin-top: 25px; font-size: 14px;
            color: rgba(255,255,255,0.8); text-decoration: none; transition: 0.3s;
            border: 1px solid rgba(255,255,255,0.3); padding: 5px 15px; border-radius: 20px;
        }
        .back-link:hover { background: rgba(255,255,255,0.1); color: #fff; text-decoration: none; }
        .alert-custom { border-radius: 10px; padding: 10px; margin-bottom: 20px; font-weight: bold; font-size: 13px; }
        .alert-danger-custom { background: rgba(255,255,255,0.9); color: #e74a3b; }
        .alert-success-custom { background: rgba(255,255,255,0.9); color: #1cc88a; }
    </style>
</head>

<body>

    <div class="login-card" id="forgotCard">
        <div class="login-icon"><i class="fas fa-key"></i></div>

        <div class="login-header">
            <h2>Quên mật khẩu?</h2>
            <p>Đừng lo lắng! Nhập email đã đăng ký của bạn và chúng tôi sẽ gửi hướng dẫn đặt lại mật khẩu.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert-custom alert-danger-custom"><i class="fas fa-exclamation-triangle mr-1"></i> @ViewBag.Error</div>
        }
        @if (ViewBag.Success != null)
        {
            <div class="alert-custom alert-success-custom"><i class="fas fa-check-circle mr-1"></i> @ViewBag.Success</div>
        }

        @using (Html.BeginForm("ForgotPassword", "Auth", FormMethod.Post, new { id = "frmForgot" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                <i class="fas fa-envelope input-icon"></i>
                <input type="email" id="email" name="email" class="form-control-custom" placeholder="Nhập địa chỉ Email...">
                <div class="invalid-feedback-custom" id="err-email">Vui lòng nhập Email hợp lệ!</div>
            </div>

            <button type="submit" class="btn-login">
                <i class="fas fa-paper-plane mr-2"></i> GỬI YÊU CẦU
            </button>
        }

        <a href="@Url.Action("Login")" class="back-link">
            <i class="fas fa-arrow-left mr-1"></i> Quay lại Đăng nhập
        </a>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script>
        $(document).ready(function () {

            $('#frmForgot').on('submit', function (e) {
                var email = $('#email').val().trim();
                var isValid = true;

                $('#email').removeClass('is-invalid');
                $('#err-email').hide();

                if (email == '') {
                    isValid = false;
                    $('#email').addClass('is-invalid');
                    $('#err-email').text("Vui lòng nhập địa chỉ Email!").show();
                }
                else if (!validateEmail(email)) {
                    isValid = false;
                    $('#email').addClass('is-invalid');
                    $('#err-email').text("Địa chỉ Email không đúng định dạng!").show();
                }

                if (!isValid) {
                    e.preventDefault(); 
                    $('#forgotCard').addClass('shake-animation');
                    setTimeout(function () {
                        $('#forgotCard').removeClass('shake-animation');
                    }, 500);
                }
            });

            $('#email').on('input', function () {
                $(this).removeClass('is-invalid');
                $('#err-email').hide();
            });

            function validateEmail(email) {
                var re = /\S+@@\S+\.\S+/; 
                return re.test(email);
            }
        });
    </script>

</body>
</html>