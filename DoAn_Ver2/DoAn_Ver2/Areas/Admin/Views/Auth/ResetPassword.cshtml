@{
    Layout = null;
    string bgLogin = DoAn_Ver2.Common.ConfigHelper.Get("BannerLogin");
    if (string.IsNullOrEmpty(bgLogin)) { bgLogin = "/Content/images/config/bg-login.jpg"; }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Đặt lại mật khẩu - Men Store Admin</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Nunito', sans-serif;
            height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: url('@bgLogin') no-repeat center center fixed;
            background-size: cover;
            position: relative;
            overflow: hidden;
        }

        body::before {
            content: ""; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.1); z-index: 0;
        }

        
        @Html.Raw("@")keyframes slideDown {
            from{ opacity: 0; transform: translateY(-50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @Html.Raw("@")keyframes shake {
            0% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            50% { transform: translateX(10px); }
            75% { transform: translateX(-10px); }
            100% { transform: translateX(0); }
        }

        .shake-animation { animation: shake 0.4s ease-in-out; }

        .login-card {
            position: relative; z-index: 1; width: 100%; max-width: 450px; padding: 40px 30px;
            border-radius: 15px;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            box-shadow: 0 15px 25px rgba(0,0,0,0.3);
            color: #fff; text-align: center;
            animation: slideDown 0.8s ease-out forwards;
        }

        .login-header h2 { font-weight: 700; font-size: 24px; margin-bottom: 5px; }
        .login-header p { font-size: 14px; opacity: 0.8; margin-bottom: 25px; }
        .login-icon { font-size: 50px; margin-bottom: 15px; opacity: 0.9; }

        .form-group { position: relative; margin-bottom: 25px; text-align: left; }

        .form-control-custom {
            width: 100%; padding: 12px 20px 12px 45px;
            border: 2px solid transparent; border-radius: 30px;
            font-size: 14px; outline: none; background: #fff; color: #333; transition: all 0.3s;
        }
        .form-control-custom:focus { box-shadow: 0 0 10px rgba(255,255,255,0.5); }
        .form-control-custom.is-invalid { border-color: #ff6b6b; background-color: #fff0f0; }

        .invalid-feedback-custom {
            color: #ff6b6b; font-size: 12px; font-weight: bold;
            margin-top: 5px; margin-left: 20px; display: none;
        }

        .input-icon {
            position: absolute; left: 15px; top: 22px; transform: translateY(-50%);
            color: #666; font-size: 16px;
        }

        .btn-login {
            width: 100%; padding: 12px; border-radius: 30px; border: none;
            background: linear-gradient(to right, #0f2027, #203a43, #2c5364);
            color: #fff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;
            cursor: pointer; transition: all 0.3s; margin-top: 5px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.3); color: #fff; }

        .alert-custom { border-radius: 10px; padding: 10px; margin-bottom: 20px; font-weight: bold; font-size: 13px; }
        .alert-danger-custom { background: rgba(255,255,255,0.9); color: #e74a3b; }
    </style>
</head>

<body>

    <div class="login-card" id="resetCard">
        <div class="login-icon"><i class="fas fa-lock-open"></i></div>

        <div class="login-header">
            <h2>Thiết lập mật khẩu mới</h2>
            <p>Vui lòng nhập mật khẩu mới cho tài khoản của bạn.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert-custom alert-danger-custom"><i class="fas fa-exclamation-triangle mr-1"></i> @ViewBag.Error</div>
        }

        @using (Html.BeginForm("ResetPassword", "Auth", FormMethod.Post, new { id = "frmReset" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="token" value="@ViewBag.Token" />

            <div class="form-group">
                <i class="fas fa-key input-icon"></i>
                <input type="password" id="newPassword" name="newPassword" class="form-control-custom" placeholder="Mật khẩu mới">
                <div class="invalid-feedback-custom" id="err-new">Vui lòng nhập mật khẩu mới!</div>
            </div>

            <div class="form-group">
                <i class="fas fa-check-circle input-icon"></i>
                <input type="password" id="confirmPassword" name="confirmPassword" class="form-control-custom" placeholder="Xác nhận mật khẩu">
                <div class="invalid-feedback-custom" id="err-confirm">Vui lòng xác nhận mật khẩu!</div>
            </div>

            <button type="submit" class="btn-login">
                <i class="fas fa-save mr-2"></i> ĐỔI MẬT KHẨU
            </button>
        }
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script>
        $(document).ready(function () {

            // Xử lý Validate
            $('#frmReset').on('submit', function (e) {
                var newPass = $('#newPassword').val().trim();
                var confirmPass = $('#confirmPassword').val().trim();
                var isValid = true;

                // Reset lỗi
                $('.form-control-custom').removeClass('is-invalid');
                $('.invalid-feedback-custom').hide();

                if (newPass == '') {
                    isValid = false;
                    $('#newPassword').addClass('is-invalid');
                    $('#err-new').text("Vui lòng nhập mật khẩu mới!").show();
                }
                else if (newPass.length < 6) {
                    isValid = false;
                    $('#newPassword').addClass('is-invalid');
                    $('#err-new').text("Mật khẩu phải có ít nhất 6 ký tự!").show();
                }

                if (confirmPass == '') {
                    isValid = false;
                    $('#confirmPassword').addClass('is-invalid');
                    $('#err-confirm').text("Vui lòng xác nhận mật khẩu!").show();
                }
                else if (confirmPass != newPass) {
                    isValid = false;
                    $('#confirmPassword').addClass('is-invalid');
                    $('#err-confirm').text("Mật khẩu xác nhận không khớp!").show();
                }

                if (!isValid) {
                    e.preventDefault();
                    $('#resetCard').addClass('shake-animation');
                    setTimeout(function() {
                        $('#resetCard').removeClass('shake-animation');
                    }, 500);
                }
            });

           
            $('.form-control-custom').on('input', function() {
                $(this).removeClass('is-invalid');
                $(this).next('.invalid-feedback-custom').hide();
            });
        });
    </script>

</body>
</html>