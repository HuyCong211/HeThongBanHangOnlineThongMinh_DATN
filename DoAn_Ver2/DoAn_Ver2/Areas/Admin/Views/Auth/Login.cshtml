@{
    Layout = null;
    string bgLogin = DoAn_Ver2.Common.ConfigHelper.Get("BannerLogin");
    if (string.IsNullOrEmpty(bgLogin)) { bgLogin = "/Content/images/config/bg-login.jpg"; }
    string hieuung = DoAn_Ver2.Common.ConfigHelper.Get("SiteEffect");

}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Đăng nhập hệ thống - Men Store Admin</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Nunito', sans-serif;
            height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: url('@bgLogin') no-repeat center center fixed;
            background-size: cover;
            position: relative;
            overflow: hidden;
        }

        body::before {
            content: ""; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.1); z-index: 0;
        }

        /* --- ANIMATION --- */
        @@keyframes slideDown {
            from { opacity: 0; transform: translateY(-50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes shake {
            0% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            50% { transform: translateX(10px); }
            75% { transform: translateX(-10px); }
            100% { transform: translateX(0); }
        }

        .shake-animation {
            animation: shake 0.4s ease-in-out;
        }

        .login-card {
            position: relative; z-index: 1; width: 100%; max-width: 400px; padding: 40px 30px;
            border-radius: 15px;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            box-shadow: 0 15px 25px rgba(0,0,0,0.3);
            color: #fff; text-align: center;
            animation: slideDown 0.8s ease-out forwards;
        }

        .login-header h2 { font-weight: 700; font-size: 24px; margin-bottom: 5px; }
        .login-header p { font-size: 14px; opacity: 0.8; margin-bottom: 25px; }
        .login-icon { font-size: 50px; margin-bottom: 15px; opacity: 0.9; }

        .form-group { position: relative; margin-bottom: 25px; /* Tăng margin để chứa lỗi */ text-align: left; }

        .form-control-custom {
            width: 100%; padding: 12px 20px 12px 45px;
            border: 2px solid transparent; /* Viền trong suốt */
            border-radius: 30px; font-size: 14px; outline: none;
            background: #fff; color: #333; transition: all 0.3s;
        }
        .form-control-custom:focus { box-shadow: 0 0 10px rgba(255,255,255,0.5); }

        /* Style lỗi */
        .form-control-custom.is-invalid {
            border-color: #ff6b6b;
            background-color: #fff0f0;
        }

        .invalid-feedback-custom {
            color: #ff6b6b;
            font-size: 12px;
            font-weight: bold;
            margin-top: 5px;
            margin-left: 20px;
            display: none; /* Mặc định ẩn */
        }

        .input-icon {
            position: absolute; left: 15px; top: 22px; /* Chỉnh lại top vì form-group có label error */
            transform: translateY(-50%); color: #666; font-size: 16px;
        }

        /* CHECKBOX */
        .custom-control-label { font-size: 13px; cursor: pointer; padding-left: 5px; user-select: none; }
        .custom-checkbox .custom-control-input:checked ~ .custom-control-label::before {
            background-color: #0f2027; border-color: #0f2027;
        }

        .btn-login {
            width: 100%; padding: 12px; border-radius: 30px; border: none;
            background: linear-gradient(to right, #0f2027, #203a43, #2c5364);
            color: #fff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;
            cursor: pointer; transition: all 0.3s; margin-top: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.3); color: #fff; }

        .forgot-pass {
            display: block; margin-top: 20px; font-size: 13px;
            color: rgba(255,255,255,0.7); text-decoration: none; transition: 0.3s;
        }
        .forgot-pass:hover { color: #fff; text-decoration: underline; }

        .alert-custom {
            background: rgba(255,255,255,0.9); color: #e74a3b; font-size: 13px;
            border-radius: 10px; padding: 10px; margin-bottom: 20px; font-weight: bold;
        }
    </style>
</head>

<body>

    <div class="login-card" id="loginCard">
        <div class="login-icon"><i class="fas fa-user-shield"></i></div>
        <div class="login-header">
            <h2>Hệ thống Quản trị</h2>
            <p>Website Thời Trang Nam</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert-custom"><i class="fas fa-exclamation-triangle mr-1"></i> @ViewBag.Error</div>
        }

        @using (Html.BeginForm("Login", "Auth", FormMethod.Post, new { id = "frmLogin" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                <i class="fas fa-envelope input-icon"></i>
                <input type="text" id="username" name="username" class="form-control-custom" placeholder="Tên đăng nhập / Email">
                <div class="invalid-feedback-custom" id="err-username">Vui lòng nhập tên đăng nhập!</div>
            </div>

            <div class="form-group mb-2">
                <i class="fas fa-lock input-icon"></i>
                <input type="password" id="password" name="password" class="form-control-custom" placeholder="Mật khẩu">
                <div class="invalid-feedback-custom" id="err-password">Vui lòng nhập mật khẩu!</div>
            </div>

            <div class="form-group text-left pl-3 mb-3">
                <div class="custom-control custom-checkbox">
                    <input type="checkbox" class="custom-control-input" id="rememberMe">
                    <label class="custom-control-label text-white-50" for="rememberMe">Nhớ mật khẩu</label>
                </div>
            </div>

            <button type="submit" class="btn-login">
                <i class="fas fa-sign-in-alt mr-2"></i> Đăng nhập
            </button>
        }

        <a href="@Url.Action("ForgotPassword")" class="forgot-pass">Quên mật khẩu?</a>
        <a href="/" class="forgot-pass" style="margin-top: 5px; opacity: 0.5;">&larr; Về trang chủ</a>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script>
        $(document).ready(function () {

            // Xử lý khi submit form
            $('#frmLogin').on('submit', function (e) {
                var isValid = true;

                // Reset lỗi cũ
                $('.form-control-custom').removeClass('is-invalid');
                $('.invalid-feedback-custom').hide();

                // Check Username
                var user = $('#username').val().trim();
                if (user == '') {
                    $('#username').addClass('is-invalid');
                    $('#err-username').show();
                    isValid = false;
                }

                // Check Password
                var pass = $('#password').val().trim();
                if (pass == '') {
                    $('#password').addClass('is-invalid');
                    $('#err-password').show();
                    isValid = false;
                }

                if (!isValid) {
                    e.preventDefault(); // Chặn submit

                    // Hiệu ứng rung lắc form
                    $('#loginCard').addClass('shake-animation');
                    setTimeout(function () {
                        $('#loginCard').removeClass('shake-animation');
                    }, 500);
                }
            });

            // Xóa lỗi khi người dùng bắt đầu gõ
            $('.form-control-custom').on('input', function () {
                $(this).removeClass('is-invalid');
                $(this).next('.invalid-feedback-custom').hide();
            });
        });
    </script>



