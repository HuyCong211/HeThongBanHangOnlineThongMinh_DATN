@model DoAn_Ver2.Models.SanPham

@{
    ViewBag.Title = "Chi tiết sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";

    var culture = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
    var listSKU = ViewBag.ListSKU as List<DoAn_Ver2.Models.BienTheSanPham>;
    var mauMap = ViewBag.MauMap as Dictionary<int, string>;
    var sizeMap = ViewBag.SizeMap as Dictionary<int, string>;
    string strMauSac = "Chưa có";
    string strKichThuoc = "Chưa có";

    if (listSKU != null && listSKU.Count > 0)
    {
        var listTenMau = listSKU.Select(x => x.MauSacID)
                                .Distinct()
                                .Where(id => mauMap != null && mauMap.ContainsKey(id))
                                .Select(id => mauMap[id])
                                .ToList();
        var listTenSize = listSKU.Select(x => x.KichThuocID)
                                 .Distinct()
                                 .Where(id => sizeMap != null && sizeMap.ContainsKey(id))
                                 .Select(id => sizeMap[id])
                                 .ToList();
        if (listTenMau.Any())
        {
            strMauSac = string.Join(" / ", listTenMau);
        }

        if (listTenSize.Any())
        {
            strKichThuoc = string.Join(" / ", listTenSize);
        }
    }
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">
            Chi tiết: @Model.TenSanPham
            <small class="text-muted">(@(Model.MaSanPham ?? "Chưa có mã"))</small>
        </h6>
        <div>
            <a href="@Url.Action("Edit", new { id = Model.ID })" class="btn btn-warning btn-sm">
                <i class="fas fa-edit"></i> Sửa
            </a>
            <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-5">
                <div class="card mb-3">
                    <div class="card-header bg-light font-weight-bold">Ảnh đại diện</div>
                    <div class="card-body text-center bg-dark">
                        @{ string mainImg = ViewBag.AnhChinh as string; }
                        <img src="@(string.IsNullOrEmpty(mainImg) ? "https://via.placeholder.com/400x400" : mainImg)"
                             class="img-fluid rounded"
                             style="max-height: 400px; object-fit: contain;"
                             alt="Ảnh chính" />
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-light font-weight-bold">Album ảnh chi tiết</div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap">
                            @if (ViewBag.AnhPhu != null)
                            {
                                var listAnh = ViewBag.AnhPhu as List<DoAn_Ver2.Models.AnhSanPham>;
                                if (listAnh != null && listAnh.Count > 0)
                                {
                                    foreach (var img in listAnh)
                                    {
                                        <div class="p-1">
                                            <img src="@img.URL" class="img-thumbnail" style="width: 80px; height: auto; object-fit: cover;" />
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted font-italic">Không có ảnh phụ nào.</span>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="card mb-4">
                    <div class="card-header bg-info text-white">Thông tin bán hàng</div>
                    <div class="card-body">
                        <table class="table table-striped table-bordered">
                            <tbody>
                                <tr>
                                    <th style="width: 150px">Tên sản phẩm:</th>
                                    <td class="font-weight-bold text-primary">@Model.TenSanPham</td>
                                </tr>
                                <tr>
                                    <th>Mã sản phẩm:</th>
                                    <td>@Model.MaSanPham</td>
                                </tr>
                                <tr>
                                    <th>Danh mục:</th>
                                    <td>@ViewBag.TenDanhMuc</td>
                                </tr>

                                <tr>
                                    <th>Slug (SEO):</th>
                                    <td class="font-italic text-muted">@Model.Slug</td>
                                </tr>
                                <tr>
                                    <th>Giá bán:</th>
                                    <td class="text-danger font-weight-bold" style="font-size: 1.2rem;">
                                        @(Model.GiaBan.HasValue ? String.Format(culture, "{0:N0} đ", Model.GiaBan) : "Liên hệ")
                                    </td>
                                </tr>
                                <tr>
                                    <th>Giá gốc:</th>
                                    <td>
                                        @(Model.GiaGoc.HasValue ? String.Format(culture, "{0:N0} đ", Model.GiaGoc) : "---")
                                    </td>
                                </tr>
                                <tr>
                                    <th>Trạng thái:</th>
                                    <td>
                                        @if (Model.TrangThai == 1)
                                        {
                                            <span class="badge badge-success px-2 py-1">Đang bán</span>
                                        }
                                        else if (Model.TrangThai == 2)
                                        {
                                            <span class="badge badge-warning px-2 py-1">Hết hàng</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary px-2 py-1">Ngừng kinh doanh</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th>Thuộc tính:</th>
                                    <td>
                                        <span class="badge badge-info">Chất liệu: @(Model.ChatLieu ?? "N/A")</span>
                                        <span class="badge badge-dark">Kiểu dáng: @(Model.KieuDang ?? "N/A")</span>
                                    </td>
                                </tr>

                                <tr>
                                    <th>Biến thể:</th>
                                    <td>
                                        <div><strong>Màu sắc:</strong> @strMauSac</div>
                                        <div><strong>Kích thước:</strong> @strKichThuoc</div>
                                        <div class="mt-2">
                                            <a href="@Url.Action("Index", "BienThe", new { sanPhamId = Model.ID })" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-cog"></i> Quản lý chi tiết SKU
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Ngày tạo:</th>
                                    <td>@Model.NgayTao.Value.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                                <tr>
                                    <th>Ngày cập nhật:</th>
                                    <td>@Model.NgayCapNhat.Value.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                                <tr>
                                    <th>Lượt xem:</th>
                                    <td>@Model.LuotXem</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>


            </div>

            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-secondary text-white">Bài viết mô tả</div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.MoTa))
                        {
                            <div class="product-description border p-3 bg-light">
                                @Html.Raw(Model.MoTa)
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">Chưa có bài viết mô tả.</p>
                        }
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>