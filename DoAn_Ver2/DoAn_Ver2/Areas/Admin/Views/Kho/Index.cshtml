@using PagedList.Mvc
@using PagedList
@using DoAn_Ver2.Models
@model IPagedList<BienTheSanPham>

@{
    ViewBag.Title = "Quản lý Tồn kho";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var mapTenSP = ViewBag.MapTenSP as Dictionary<int, string>;
    var mapMau = ViewBag.MapMau as Dictionary<int, MauSac>;
    var mapSize = ViewBag.MapSize as Dictionary<int, string>;
}

<style>
    .pagination-container ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
    }

    .pagination-container li {
        margin-right: 5px;
    }

        .pagination-container li a, .pagination-container li span {
            position: relative;
            display: block;
            padding: 0.5rem 0.75rem;
            margin-left: -1px;
            line-height: 1.25;
            color: #007bff;
            background-color: #fff;
            border: 1px solid #dee2e6;
            text-decoration: none;
            border-radius: 3px;
        }

    .pagination-container .active span {
        z-index: 1;
        color: #fff;
        background-color: #007bff;
        border-color: #007bff;
    }
</style>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">TỔNG KHO HÀNG HÓA</h6>
    </div>
    <div class="card-body">

        @using (Html.BeginForm("Index", "Kho", FormMethod.Get, new { @class = "mb-3" }))
        {


            <div class="form-row align-items-end">
                <div class="col-md-4 mb-2">
                    <label class="small mb-1">Từ khóa (Tên, Mã, Slug)</label>
                    <input type="text" name="searchString" value="@ViewBag.CurrentFilter" class="form-control" placeholder="Nhập tên sản phẩm hoặc mã SKU..." />
                </div>
                <div class="col-md-3 mb-2">
                    <label class="small mb-1">Danh mục sản phẩm</label>
                    @Html.DropDownList("danhMucId", (SelectList)ViewBag.ListDanhMuc, "--- Tất cả danh mục ---", new { @class = "form-control" })
                </div>
                <div class="col-md-2 mb-2">
                    <label class="small text-muted mb-1">Hiển thị</label>
                    <select name="pageSize" class="form-control">
                        <option value="5" @(ViewBag.PageSize == 5 ? "selected" : "")>5 dòng</option>
                        <option value="10" @(ViewBag.PageSize == 10 ? "selected" : "")>10 dòng</option>
                        <option value="20" @(ViewBag.PageSize == 20 ? "selected" : "")>20 dòng</option>
                        <option value="50" @(ViewBag.PageSize == 50 ? "selected" : "")>50 dòng</option>
                    </select>
                </div>
                <div class="col-md-1 mb-2">
                    <button type="submit" class="btn btn-info btn-block"><i class="fas fa-search"></i>Tìm</button>
                </div>

                <div class="col-md-1 mb-2">
                    <a href="@Url.Action("Index")" class="btn btn-secondary btn-block" title="Reset"><i class="fas fa-sync"></i></a>
                </div>
            </div>


        }

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Message"]
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th>STT</th>
                        <th>SKU</th>
                        <th>Sản phẩm</th>
                        <th>Phân loại</th>
                        <th class="text-center">Tồn kho</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Tác vụ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        // Khai báo biến đếm
                        int i = 0;
                        int pageSize = ViewBag.PageSize;
                        int pageNumber = Model.PageNumber;

                        foreach (var item in Model)
                        {
                            i++;
                            int stt = (pageNumber - 1) * pageSize + i;
                            string tenSP = (mapTenSP != null && mapTenSP.ContainsKey(item.SanPhamID)) ? mapTenSP[item.SanPhamID] : "---";
                            MauSac objMau = (mapMau != null && mapMau.ContainsKey(item.MauSacID)) ? mapMau[item.MauSacID] : null;
                            string tenSize = (mapSize != null && mapSize.ContainsKey(item.KichThuocID)) ? mapSize[item.KichThuocID] : "-";

                            <tr>
                                <td class="text-center font-weight-bold">@stt</td>
                                <td class="font-weight-bold text-primary">@item.SKU</td>
                                <td class="font-weight-bold">@tenSP</td>
                                <td>
                                    @if (objMau != null)
                                    {
                                        <span class="badge border text-dark mr-1" style="background: @objMau.MaHex; color: #fff;">@objMau.TenMau</span>
                                    }
                                    <span class="badge badge-secondary">@tenSize</span>
                                </td>
                                <td class="font-weight-bold text-center" style="font-size: 1.1rem">
                                    @item.SoLuong
                                </td>
                                <td class="text-center">
                                    @if (item.SoLuong <= 0)
                                    {
                                        <span class="badge badge-danger px-2 py-1">Hết hàng</span>
                                    }
                                    else if (item.SoLuong < 10)
                                    {
                                        <span class="badge badge-warning px-2 py-1">Sắp hết</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-success px-2 py-1">Sẵn sàng</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("NhapHang", new { id = item.ID })" class="btn btn-primary btn-sm mb-1">
                                        <i class="fas fa-plus"></i> Nhập
                                    </a>
                                    <a href="@Url.Action("LichSu", new { id = item.ID })" class="btn btn-info btn-sm mb-1">
                                        <i class="fas fa-history"></i> Lịch sử
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Không tìm thấy dữ liệu phù hợp.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap">
            <div class="small text-muted mb-2">
                Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) / @Model.PageCount
                (Tổng: @Model.TotalItemCount SKU)
            </div>
            <div class="d-flex align-items-center mb-2">
                <div class="mr-3">
                    @Html.PagedListPager(Model, page => Url.Action("Index", new
                    {
                        page,
                        searchString = ViewBag.CurrentFilter,
                        danhMucId = ViewBag.CurrentDanhMuc,
                        pageSize = ViewBag.PageSize
                    }),
                    new PagedListRenderOptions
                    {
                        DisplayLinkToFirstPage = PagedListDisplayMode.Always, 
                        DisplayLinkToLastPage = PagedListDisplayMode.Always,  
                        DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                        DisplayLinkToNextPage = PagedListDisplayMode.Always,
                        MaximumPageNumbersToDisplay = 5,

                        DisplayEllipsesWhenNotShowingAllPageNumbers = true,
                        LinkToFirstPageFormat = "«",
                        LinkToPreviousPageFormat = "‹",
                        LinkToNextPageFormat = "›",
                        LinkToLastPageFormat = "»",

                    })
                </div>

                @using (Html.BeginForm("Index", "Kho", FormMethod.Get, new { @class = "form-inline" }))
                {
                    <input type="hidden" name="searchString" value="@ViewBag.CurrentFilter" />
                    <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />

                    <div class="input-group input-group-sm">
                        <input type="number" name="page" class="form-control" placeholder="Trang..."
                               min="1" max="@Model.PageCount" style="width: 70px;" required>
                        <div class="input-group-append">
                            <button class="btn btn-primary" type="submit">Đến</button>
                        </div>
                    </div>
                }
            </div>
        </div>


    </div>
</div>