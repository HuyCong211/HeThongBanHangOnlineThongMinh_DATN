@using PagedList.Mvc
@model PagedList.IPagedList<DoAn_Ver2.Models.MaGiamGia>

@{
    ViewBag.Title = "Quản lý Mã giảm giá";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách Mã giảm giá</h6>
        <a href="@Url.Action("Create")" class="btn btn-success btn-sm font-weight-bold">
            <i class="fas fa-plus mr-1"></i> Thêm mới
        </a>
    </div>
    <div class="card-body">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <form action="@Url.Action("Index")" method="get" class="form-inline mb-4">
            <div class="input-group">
                <input type="text" name="searchString" value="@ViewBag.CurrentFilter" class="form-control" placeholder="Nhập mã code...">
                <div class="input-group-append">
                    <button class="btn btn-primary" type="button">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                <thead class="thead-light">
                    <tr>
                        <th>Mã Code</th>
                        <th>Loại giảm</th>
                        <th>Giá trị</th>
                        <th>Đơn tối thiểu</th>
                        <th>Số lượng</th>
                        <th>Hạn sử dụng</th>
                        <th>Tác vụ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            bool isExpired = item.NgayHetHan < DateTime.Now;
                            <tr class="@(isExpired ? "table-secondary text-muted" : "")">
                                <td class="font-weight-bold text-primary">@item.MaCode</td>
                                <td>
                                    @if (item.LoaiGiam == "PERCENT")
                                    {<span class="badge badge-info">% Phần trăm</span> }
                                    else
                                    { <span class="badge badge-success">$ Tiền mặt</span>}
                                </td>
                                <td class="font-weight-bold">
                                    @(item.LoaiGiam == "PERCENT" ? item.GiaTri?.ToString("N0") + "%" : item.GiaTri?.ToString("N0") + " đ")
                                </td>
                                <td>@(item.DonToiThieu?.ToString("N0") ?? "0") đ</td>
                                <td>@item.SoLuong</td>
                                <td>
                                    @if (isExpired)
                                    {
                                        <span class="text-danger small font-weight-bold">Đã hết hạn</span><br>
                                    }
                                    @(item.NgayHetHan?.ToString("dd/MM/yyyy HH:mm"))
                                </td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = item.ID })" class="btn btn-info btn-sm" title="Xem chi tiết & Lịch sử">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = item.ID })" class="btn btn-warning btn-sm" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-danger btn-sm" onclick="DeleteVoucher(@item.ID)" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center">Không có dữ liệu</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="float-right">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, searchString = ViewBag.CurrentFilter }),
                new PagedListRenderOptions
                     {
                    LiElementClasses = new string[] { "page-item" },
                    FunctionToTransformEachPageLink = (li, a) => { a.AddCssClass("page-link"); return a; }
                })
        </div>
    </div>
</div>

<!-- MODAL: Cảnh báo có đơn hàng (chặn xóa) -->
<div class="modal fade" id="modalHasOrders" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="fas fa-ban mr-2"></i>Không thể xóa</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <p>Mã <strong id="lblMaCode"></strong> đã được áp dụng trong đơn hàng — <strong class="text-danger">không thể xóa.</strong></p>
                <div class="alert alert-info mb-0">
                    <i class="fas fa-lightbulb mr-1"></i>
                    <strong>Gợi ý:</strong> Vô hiệu hóa mã bằng cách chỉnh <em>Ngày hết hạn</em> về ngày trong quá khứ.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
                <a href="#" id="btnGoEdit" class="btn btn-warning">
                    <i class="fas fa-edit mr-1"></i> Vô hiệu hóa ngay
                </a>
            </div>
        </div>
    </div>
</div>

<!-- MODAL: Xác nhận xóa (chỉ hiện khi không có đơn hàng) -->
<div class="modal fade" id="modalConfirmDelete" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle mr-2"></i>Xác nhận xóa</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                Bạn có chắc muốn <strong>xóa vĩnh viễn</strong> mã <strong id="lblMaCodeConfirm"></strong>?<br>
                <small class="text-muted">Hành động này không thể hoàn tác.</small>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" id="btnConfirmDelete">
                    <i class="fas fa-trash mr-1"></i> Xóa
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    var _deleteId = null;

    function DeleteVoucher(id) {
        // Bước 1: Check có đơn hàng không TRƯỚC
        $.ajax({
            url: '/Admin/Marketing/CheckDelete',
            type: 'POST',
            data: { id: id },
            success: function (res) {
                if (!res.found) {
                    alert('Không tìm thấy mã.');
                    return;
                }

                if (res.hasOrders) {
                    // Có đơn hàng → cảnh báo, chặn luôn
                    $('#lblMaCode').text(res.maCode);
                    $('#btnGoEdit').attr('href', res.editUrl);
                    $('#modalHasOrders').modal('show');
                } else {
                    // Không có đơn hàng → hỏi xác nhận
                    _deleteId = id;
                    $('#lblMaCodeConfirm').text(res.maCode);
                    $('#modalConfirmDelete').modal('show');
                }
            }
        });
    }

    // Bước 2: Xác nhận → mới gọi Delete
    $('#btnConfirmDelete').on('click', function () {
        $('#modalConfirmDelete').modal('hide');
        $.ajax({
            url: '/Admin/Marketing/Delete',
            type: 'POST',
            data: { id: _deleteId },
            success: function (res) {
                if (res.success) {
                    location.reload();
                } else {
                    alert('Lỗi: ' + res.message);
                }
            }
        });
    });
</script>