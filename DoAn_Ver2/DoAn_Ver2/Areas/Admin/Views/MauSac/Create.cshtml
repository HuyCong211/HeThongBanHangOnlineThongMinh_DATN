@model DoAn_Ver2.Models.MauSac

@{
    ViewBag.Title = "Thêm màu sắc";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow" style="max-width: 600px; margin: 0 auto;">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Thêm màu sắc mới</h6>
    </div>
    <div class="card-body">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Tên màu <span class="text-danger">(*)</span></label>
                @Html.EditorFor(model => model.TenMau, new { htmlAttributes = new { @class = "form-control", required = "required", placeholder = "VD: Đỏ đô, Xanh Navy..." } })
                @Html.ValidationMessageFor(model => model.TenMau, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <label>Chọn mã màu (Color Picker) <span class="text-danger">(*)</span></label>
                <div class="input-group">
                    @Html.EditorFor(model => model.MaHex, new { htmlAttributes = new { @class = "form-control", type = "color", style = "height: 50px; max-width: 100px; padding: 5px;" } })

                    <div class="input-group-append">
                        <span class="input-group-text bg-white border-left-0 text-muted">Click vào ô bên trái để chọn màu chuẩn</span>
                    </div>
                </div>
                @Html.ValidationMessageFor(model => model.MaHex, "", new { @class = "text-danger" })
            </div>

            <div class="form-group text-center mt-4">
                <a href="@Url.Action("Index")" class="btn btn-secondary mr-2">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
                <button type="submit" class="btn btn-success px-4">
                    <i class="fas fa-save"></i> Lưu lại
                </button>
            </div>
        }
    </div>
</div>