@using PagedList.Mvc
@model PagedList.IPagedList<DoAn_Ver2.Models.TinTuc>

@{
    ViewBag.Title = "Quản lý Tin tức";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách Bài viết</h6>
        <a href="@Url.Action("Create")" class="btn btn-success btn-sm font-weight-bold">
            <i class="fas fa-plus mr-1"></i> Viết bài mới
        </a>
    </div>
    <div class="card-body">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <form action="@Url.Action("Index")" method="get" class="form-inline mb-4">
            <input type="text" name="searchString" value="@ViewBag.CurrentFilter" class="form-control mr-2" placeholder="Tìm tiêu đề...">
            <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i> Tìm kiếm</button>
        </form>

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" width="100%" cellspacing="0">
                <thead class="thead-light text-center">
                    <tr>
                        <th width="100">Hình ảnh</th>
                        <th>Tiêu đề / Tóm tắt</th>
                        <th width="120">Ngày đăng</th>
                        <th width="120">Trạng thái</th>
                        <th width="150">Tác vụ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center align-middle">
                                    <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "/Content/images/no-image.png" : item.HinhAnh)"
                                         style="width: 80px; height: 60px; object-fit:cover; border-radius: 4px; border: 1px solid #eee;" />
                                </td>
                                <td class="align-middle">
                                    <div style="font-weight: bold; font-size: 1.1em; line-height: 1.2; margin-bottom: 5px;">
                                        <a href="@Url.Action("Details", new { id = item.ID })" class="text-primary text-decoration-none">
                                            @item.TieuDe
                                        </a>
                                    </div>
                                    <div class="text-muted small" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                                        @item.TomTat
                                    </div>
                                </td>
                                <td class="text-center align-middle">
                                    @item.NgayDang.Value.ToString("dd/MM/yyyy")
                                </td>
                                <td class="text-center align-middle">
                                    @if (item.TrangThai == true)
                                    {
                                        <span class="badge badge-success px-2 py-1">Hiển thị</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary px-2 py-1">Ẩn</span>
                                    }
                                </td>
                                <td class="text-center align-middle text-nowrap">
                                    <a href="@Url.Action("Details", new { id = item.ID })" class="btn btn-info btn-sm" title="Xem">
                                        <i class="fas fa-eye"></i>
                                    </a>

                                    <a href="@Url.Action("Edit", new { id = item.ID })" class="btn btn-warning btn-sm mx-1" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>

                                    <button class="btn btn-danger btn-sm" onclick="DeleteNews(@item.ID)" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-4">Chưa có bài viết nào</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="float-right">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, searchString = ViewBag.CurrentFilter }),
                new PagedListRenderOptions
                     {
                    LiElementClasses = new string[] { "page-item" },
                    FunctionToTransformEachPageLink = (li, a) => { a.AddCssClass("page-link"); return a; }
                })
        </div>
    </div>
</div>

<script>
    function DeleteNews(id) {
        if (confirm('Bạn có chắc muốn xóa bài viết này?')) {
            $.ajax({
                url: '/Admin/News/Delete',
                type: 'POST',
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        alert('Xóa thành công!');
                        location.reload();
                    } else {
                        alert('Lỗi: ' + res.message);
                    }
                }
            });
        }
    }
</script>
