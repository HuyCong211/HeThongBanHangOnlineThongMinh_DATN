@model DoAn_Ver2.Models.TinTuc

@{
    ViewBag.Title = "Cập nhật tin tức";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Cập nhật tin tức</h6>
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Edit", "News", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            @Html.HiddenFor(model => model.ID)
            @Html.HiddenFor(model => model.NgayDang)
            @Html.HiddenFor(model => model.NguoiDungID)
            @Html.HiddenFor(model => model.HinhAnh)

            <div class="row">
                <div class="col-md-9">
                    <div class="form-group">
                        <label>Tiêu đề bài viết <span class="text-danger">*</span></label>
                        @Html.EditorFor(model => model.TieuDe, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                    </div>

                    <div class="form-group">
                        <label>Tóm tắt ngắn</label>
                        @Html.TextAreaFor(model => model.TomTat, new { @class = "form-control", rows = "3" })
                    </div>

                    <div class="form-group">
                        <label>Nội dung chi tiết</label>
                        @Html.TextAreaFor(model => model.NoiDung, new { @class = "form-control", @id = "txtNoiDung" })
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-group">
                        <label>Ảnh đại diện</label>
                        <img id="imgPreview" src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "/Content/images/no-image.png" : Model.HinhAnh)"
                             class="img-thumbnail mb-2" style="width: 100%; height: 200px; object-fit: cover;" />
                        <input type="file" name="uploadBtn" class="form-control-file" accept="image/*" onchange="previewImage(this)" />
                    </div>

                    <div class="card mt-3">
                        <div class="card-header bg-light">Tùy chọn</div>
                        <div class="card-body">
                            <div class="form-group">
                                <label class="small text-muted">Ngày đăng</label>
                                <input type="text" class="form-control form-control-sm" value="@Model.NgayDang.Value.ToString("dd/MM/yyyy HH:mm")" disabled readonly />
                            </div>

                            <div class="custom-control custom-switch">
                                @{ bool isChecked = Model.TrangThai.GetValueOrDefault(false); }
                                @Html.CheckBox("TrangThai", isChecked, new { @class = "custom-control-input", @id = "switchStatus" })
                                <label class="custom-control-label" for="switchStatus">Hiển thị ngay</label>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-block mt-4 font-weight-bold"><i class="fas fa-save"></i> LƯU THAY ĐỔI</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary btn-block">Quay lại</a>
                </div>
            </div>
        }
    </div>
</div>

@section scripts {
    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
    <script>
        CKEDITOR.replace('txtNoiDung');
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imgPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}