@model DoAn_Ver2.Models.TinTuc

@{
    ViewBag.Title = "Viết bài mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Soạn thảo Tin tức</h6>
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Create", "News", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="row">
                <div class="col-md-9">
                    <div class="form-group">
                        <label>Tiêu đề bài viết <span class="text-danger">*</span></label>
                        @Html.EditorFor(model => model.TieuDe, new { htmlAttributes = new { @class = "form-control", required = "required", placeholder = "Nhập tiêu đề..." } })
                    </div>

                    <div class="form-group">
                        <label>Tóm tắt ngắn</label>
                        @Html.TextAreaFor(model => model.TomTat, new { @class = "form-control", rows = "3", placeholder = "Mô tả ngắn gọn nội dung..." })
                    </div>

                    <div class="form-group">
                        <label>Nội dung chi tiết</label>
                        @Html.TextAreaFor(model => model.NoiDung, new { @class = "form-control", @id = "txtNoiDung" })
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-group">
                        <label>Ảnh đại diện</label>
                        <img id="imgPreview" src="/Content/images/no-image.png" class="img-thumbnail mb-2" style="width: 100%; height: 200px; object-fit: cover;" />
                        <input type="file" name="uploadBtn" class="form-control-file" accept="image/*" onchange="previewImage(this)" />
                    </div>

                    <div class="card mt-3">
                        <div class="card-header bg-light">Tùy chọn</div>
                        <div class="card-body">
                            <div class="form-group">
                                <label class="small text-muted">Người đăng bài</label>
                                <input type="text" class="form-control form-control-sm" value="@ViewBag.TenNguoiDang" disabled readonly />
                            </div>

                            <div class="custom-control custom-switch">
                                @Html.CheckBox("TrangThai", true, new { @class = "custom-control-input", @id = "switchStatus" })
                                <label class="custom-control-label" for="switchStatus">Hiển thị ngay</label>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-success btn-block mt-4 font-weight-bold"><i class="fas fa-paper-plane"></i> ĐĂNG BÀI</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary btn-block">Hủy bỏ</a>
                </div>
            </div>
        }
    </div>
</div>

@section scripts {
    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
    <script>
        CKEDITOR.replace('txtNoiDung');
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imgPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}