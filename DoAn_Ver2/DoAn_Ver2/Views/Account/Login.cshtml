@model DoAn_Ver2.Models.ViewModel.LoginViewModel
@{
    ViewBag.Title = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-dark text-white text-center py-4">
                    <h3 class="font-weight-bold mb-0">ĐĂNG NHẬP</h3>
                </div>
                <div class="card-body p-4">
                    @*@if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }*@

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Tên đăng nhập / Email</label>
                            @Html.TextBoxFor(m => m.TenDangNhap, new { @class = "form-control form-control-lg", placeholder = "Nhập tài khoản..." })
                            @Html.ValidationMessageFor(m => m.TenDangNhap, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Mật khẩu</label>
                            @Html.PasswordFor(m => m.MatKhau, new { @class = "form-control form-control-lg", placeholder = "Nhập mật khẩu..." })
                            @Html.ValidationMessageFor(m => m.MatKhau, "", new { @class = "text-danger" })
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <a href="@Url.Action("ForgotPassword")" class="text-decoration-none small">Quên mật khẩu?</a>
                        </div>

                        <button type="submit" class="btn btn-dark btn-block btn-lg font-weight-bold">ĐĂNG NHẬP</button>
                    }
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small">Chưa có tài khoản? <a href="@Url.Action("Register")" class="font-weight-bold text-dark">Đăng ký ngay</a></div>
                </div>
            </div>
        </div>
    </div>
</div>