@model DoAn_Ver2.Models.ViewModel.ResetPasswordViewModel
@{
    ViewBag.Title = "Đặt lại mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h4 class="text-center font-weight-bold mb-4">MẬT KHẨU MỚI</h4>

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.Token)

                        <div class="form-group mb-3">
                            <label>Mật khẩu mới</label>
                            @Html.PasswordFor(m => m.MatKhauMoi, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.MatKhauMoi, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group mb-3">
                            <label>Xác nhận mật khẩu</label>
                            @Html.PasswordFor(m => m.XacNhanMatKhau, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.XacNhanMatKhau, "", new { @class = "text-danger" })
                        </div>

                        <button type="submit" class="btn btn-success btn-block">LƯU MẬT KHẨU</button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>