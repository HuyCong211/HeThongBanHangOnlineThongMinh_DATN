@model List<DoAn_Ver2.Models.SanPham>
@{
    ViewBag.Title = "Sản phẩm yêu thích";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="bg-light py-4 mb-4">
    <div class="container">
        <h3 class="font-weight-bold text-uppercase m-0">SẢN PHẨM YÊU THÍCH</h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb bg-transparent p-0 m-0 small">
                <li class="breadcrumb-item"><a href="/" class="text-muted">Trang chủ</a></li>
                <li class="breadcrumb-item active text-dark">Wishlist</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container pb-5">
    @if (Model != null && Model.Count > 0)
    {
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
            <p class="text-muted mb-0">
                Hiển thị trang <b>@currentPage</b>/@totalPages (Tổng <b>@Model.Count</b> sản phẩm yêu thích)
            </p>
        </div>

        <div class="row">
            @foreach (var item in Model)
            {
                string imgUrl = ViewData["Img_" + item.ID] as string;

                <div class="col-6 col-md-4 col-lg-3 mb-4" id="wish-item-@item.ID">
                    <div class="card h-100 border-0 shadow-sm product-card">

                        <div class="position-relative overflow-hidden img-wrap" style="height: 280px; display: flex; align-items: center; justify-content: center; background-color: #f8f9fa;">
                            <a href="@Url.Action("Detail", "Product", new { id = item.ID })" class="w-100 h-100 d-flex align-items-center justify-content-center">
                                <img src="@imgUrl" class="img-fluid" alt="@item.TenSanPham" style="max-height: 100%; max-width: 100%; object-fit: contain;">
                            </a>

                            <button class="btn btn-white rounded-circle shadow position-absolute btn-remove-wish"
                                    style="top: 10px; right: 10px; width: 35px; height: 35px; padding: 0; display: flex; align-items: center; justify-content: center; background: white; z-index: 10;"
                                    onclick="toggleWishlist(@item.ID, this, true)" title="Bỏ thích">
                                <i class="fas fa-times text-danger"></i>
                            </button>

                            @if (item.GiaGoc > item.GiaBan)
                            {
                                <span class="badge badge-danger position-absolute" style="top: 10px; left: 10px;">-@((int)((1 - item.GiaBan / item.GiaGoc) * 100))%</span>
                            }
                        </div>

                        <div class="card-body d-flex flex-column pt-3">
                            <h6 class="card-title mb-1 text-center">
                                <a href="@Url.Action("Detail", "Product", new { id = item.ID })" class="text-dark text-decoration-none font-weight-bold"
                                   style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 40px; line-height: 20px;">
                                    @item.TenSanPham
                                </a>
                            </h6>

                            <div class="mt-auto text-center">
                                <div class="d-flex align-items-baseline justify-content-center">
                                    <span class="text-danger font-weight-bold h5 mb-0 mr-2">
                                        @(item.GiaBan.HasValue ? item.GiaBan.Value.ToString("N0") : "Liên hệ")đ
                                    </span>
                                    @if (item.GiaGoc > item.GiaBan)
                                    {
                                        <small class="text-muted text-decoration-line-through">@item.GiaGoc.Value.ToString("N0")đ</small>
                                    }
                                </div>
                            </div>

                            <a href="@Url.Action("Detail", "Product", new { id = item.ID })" class="btn btn-outline-dark btn-sm mt-3 btn-block text-uppercase font-weight-bold">
                                <i class="fas fa-eye mr-1"></i> Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        if (totalPages > 1)
        {
            <div class="row mt-4">
                <div class="col-12 d-flex justify-content-center">
                    <nav aria-label="Page navigation">
                        <ul class="pagination shadow-sm">
                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                <a class="page-link text-dark" href="@Url.Action("Index", new { page = currentPage - 1 })" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>

                            @{
                                int startPage = Math.Max(1, currentPage - 2);
                                int endPage = Math.Min(totalPages, currentPage + 2);

                                if (startPage > 1)
                                {
                                    <li class="page-item"><a class="page-link text-dark" href="@Url.Action("Index", new { page = 1 })">1</a></li>
                                    if (startPage > 2)
                                    {
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
 }
                                }

                                for (int i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link @(i == currentPage ? "bg-dark border-dark text-white" : "text-dark")" href="@Url.Action("Index", new { page = i })">@i</a>
                                    </li>
                                }

                                if (endPage < totalPages)
                                {
                                    if (endPage < totalPages - 1)
                                    {
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
 }
                                    <li class="page-item"><a class="page-link text-dark" href="@Url.Action("Index", new { page = totalPages })">@totalPages</a></li>
                                }
                            }

                            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                                <a class="page-link text-dark" href="@Url.Action("Index", new { page = currentPage + 1 })" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5 bg-white rounded shadow-sm border">
            <div class="mb-4">
                <i class="far fa-heart fa-5x text-muted opacity-25" style="opacity: 0.3"></i>
            </div>
            <h4 class="font-weight-bold mb-2">Danh sách yêu thích trống!</h4>
            <p class="text-muted mb-4">Hãy thả tim <i class="fas fa-heart text-danger"></i> các sản phẩm bạn thích để lưu lại đây nhé.</p>
            <a href="/" class="btn btn-dark px-5 py-2 text-uppercase font-weight-bold shadow-sm hover-up">
                Tiếp tục mua sắm
            </a>
        </div>
    }
</div>

<style>
    /* CSS copy từ History để đồng bộ giao diện */
    .product-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    .img-wrap img {
        transition: transform 0.5s ease;
    }

    .product-card:hover .img-wrap img {
        transform: scale(1.05);
    }

    /* CSS riêng cho nút xóa của Wishlist */
    .btn-remove-wish {
        transition: all 0.2s;
        opacity: 0.8;
    }

        .btn-remove-wish:hover {
            opacity: 1;
            transform: scale(1.1);
        }

    /* CSS Phân trang */
    .page-link:focus {
        box-shadow: none;
    }

    .page-item.active .page-link {
        background-color: #343a40;
        border-color: #343a40;
    }
</style>