@model DoAn_Ver2.Models.ViewModel.ChangePasswordViewModel
@{
    ViewBag.Title = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-3">
            @Html.Partial("~/Views/Profile/_ProfileSidebar.cshtml")
        </div>

        <div class="col-lg-9">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white font-weight-bold text-uppercase">
                    <i class="fas fa-key mr-2"></i> Đổi mật khẩu
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @Html.ValidationSummary(false, "Vui lòng kiểm tra lại:")
                        </div>
                    }

                    @using (Html.BeginForm("ChangePassword", "Profile", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <label class="font-weight-bold">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                            @Html.PasswordFor(m => m.MatKhauCu, new { @class = "form-control", placeholder = "Nhập mật khẩu cũ..." })
                            @Html.ValidationMessageFor(m => m.MatKhauCu, "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group">
                            <label class="font-weight-bold">Mật khẩu mới <span class="text-danger">*</span></label>
                            @Html.PasswordFor(m => m.MatKhauMoi, new { @class = "form-control", placeholder = "Mật khẩu ít nhất 6 ký tự" })
                            @Html.ValidationMessageFor(m => m.MatKhauMoi, "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group">
                            <label class="font-weight-bold">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                            @Html.PasswordFor(m => m.XacNhanMatKhau, new { @class = "form-control", placeholder = "Nhập lại mật khẩu mới" })
                            @Html.ValidationMessageFor(m => m.XacNhanMatKhau, "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group text-right mt-4">
                            <button type="submit" class="btn btn-primary px-4 font-weight-bold">
                                <i class="fas fa-save mr-2"></i> LƯU THAY ĐỔI
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>