@model DoAn_Ver2.Models.TinTuc

@{
    ViewBag.Title = Model.TieuDe;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var otherNews = ViewBag.OtherNews as List<DoAn_Ver2.Models.TinTuc>;
}

<div class="bg-light py-3 border-bottom mb-4">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb bg-transparent p-0 m-0 small">
                <li class="breadcrumb-item"><a href="/" class="text-muted">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "News")" class="text-muted">Tin tức</a></li>
                <li class="breadcrumb-item active text-dark">@Model.TieuDe</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container pb-5">
    <div class="row">
        <div class="col-lg-8">
            <article>
                <h1 class="font-weight-bold mb-3">@Model.TieuDe</h1>
                <div class="text-muted mb-4 small">
                    <span class="mr-3"><i class="far fa-calendar-alt mr-1"></i> @(Model.NgayDang.HasValue ? Model.NgayDang.Value.ToString("dd/MM/yyyy") : "")</span>
                    <span><i class="far fa-user mr-1"></i> Admin</span>
                    <span><i class="far fa-eye mr-1"></i> @(Model.LuotXem ?? 0) lượt xem</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.HinhAnh))
                {
                    <img src="@Model.HinhAnh" class="img-fluid rounded mb-4 w-100" alt="@Model.TieuDe">
                }

                <div class="font-weight-bold lead mb-4 font-italic text-secondary border-left pl-3" style="border-width: 4px !important;">
                    @Model.TomTat
                </div>

                <div class="content-detail text-justify">
                    @Html.Raw(Model.NoiDung)
                </div>
            </article>

            <div class="mt-5 pt-3 border-top">
                <span class="font-weight-bold mr-2">Chia sẻ bài viết:</span>
                <a href="#" class="btn btn-sm btn-primary rounded-circle"><i class="fab fa-facebook-f"></i></a>
                <a href="#" class="btn btn-sm btn-info rounded-circle"><i class="fab fa-twitter"></i></a>
            </div>
        </div>

        <div class="col-lg-4 mt-5 mt-lg-0 pl-lg-5">
            <h5 class="font-weight-bold text-uppercase mb-4 border-bottom pb-2">Bài viết mới</h5>

            @if (otherNews != null && otherNews.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var item in otherNews)
                    {
                        <a href="@Url.Action("Details", "News", new { id = item.ID })" class="list-group-item list-group-item-action flex-column align-items-start px-0 border-bottom-0 pb-4">
                            <div class="media">
                                <img class="mr-3 rounded" src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/80" : item.HinhAnh)" alt="news" style="width: 80px; height: 60px; object-fit: cover;">
                                <div class="media-body">
                                    <h6 class="mt-0 mb-1 font-weight-bold text-dark line-clamp-2" style="font-size: 0.95rem;">@item.TieuDe</h6>
                                    <small class="text-muted">@item.NgayDang.Value.ToString("dd/MM/yyyy")</small>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .content-detail img {
        max-width: 100% !important;
        height: auto !important;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>