
@model IEnumerable<DoAn_Ver2.Models.TinTuc>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 shadow-sm hover-up-news">
                    <a href="@Url.Action("Details", "News", new { id = item.ID })" class="overflow-hidden d-block rounded-top">
                        <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/400x250" : item.HinhAnh)"
                             class="card-img-top transition-img" alt="@item.TieuDe"
                             style="height: 220px; object-fit: cover;">
                    </a>
                    <div class="card-body">
                        <small class="text-muted"><i class="far fa-clock mr-1"></i> @item.NgayDang.Value.ToString("dd/MM/yyyy")</small>
                        <h5 class="card-title mt-2 font-weight-bold" style="font-size: 1.1rem; line-height: 1.4;">
                            <a href="@Url.Action("Details", "News", new { id = item.ID })" class="text-dark text-decoration-none text-clamp-2">
                                @item.TieuDe
                            </a>
                        </h5>
                        <p class="card-text small text-secondary text-clamp-3">@item.TomTat</p>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted">Chưa có bài viết mới.</div>
    }
</div>

<style>
    .text-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .text-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .hover-up-news {
        transition: transform 0.3s;
    }

        .hover-up-news:hover {
            transform: translateY(-5px);
        }

    .transition-img {
        transition: transform 0.5s;
    }

    .hover-up-news:hover .transition-img {
        transform: scale(1.05);
    }
</style>