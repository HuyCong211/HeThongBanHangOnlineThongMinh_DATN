@using PagedList.Mvc;
@model PagedList.IPagedList<DoAn_Ver2.Models.TinTuc>

@{
    ViewBag.Title = "Tin tức";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-light py-4 border-bottom mb-5">
    <div class="container">
        <h3 class="font-weight-bold text-uppercase m-0">Tin tức & Sự kiện</h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb bg-transparent p-0 m-0 small">
                <li class="breadcrumb-item"><a href="/" class="text-muted">Trang chủ</a></li>
                <li class="breadcrumb-item active text-dark">Tin tức</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container pb-5">
    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm hover-up">
                        <a href="@Url.Action("Details", "News", new { id = item.ID })">
                            <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/400x250" : item.HinhAnh)"
                                 class="card-img-top" alt="@item.TieuDe"
                                 style="height: 200px; object-fit: cover;">
                        </a>
                        <div class="card-body">
                            <small class="text-muted d-block mb-2">
                                <i class="far fa-calendar-alt mr-1"></i> @(item.NgayDang.HasValue ? item.NgayDang.Value.ToString("dd/MM/yyyy") : "")
                            </small>
                            <h5 class="card-title font-weight-bold line-clamp-2">
                                <a href="@Url.Action("Details", "News", new { id = item.ID })" class="text-dark text-decoration-none">@item.TieuDe</a>
                            </h5>
                            <p class="card-text text-secondary small line-clamp-3">@item.TomTat</p>
                        </div>
                        <div class="card-footer bg-white border-0 pt-0">
                            <a href="@Url.Action("Details", "News", new { id = item.ID })" class="text-primary font-weight-bold small">
                                Xem chi tiết <i class="fas fa-arrow-right ml-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">Hiện chưa có bài viết nào.</p>
            </div>
        }
    </div>

    <div class="d-flex justify-content-center mt-4">
        <nav aria-label="Page navigation">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page }),
               new PagedListRenderOptions
                    {
                   LiElementClasses = new string[] { "page-item" },
               })
        </nav>
    </div>
</div>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .hover-up {
        transition: transform 0.2s;
    }

        .hover-up:hover {
            transform: translateY(-5px);
        }
</style>