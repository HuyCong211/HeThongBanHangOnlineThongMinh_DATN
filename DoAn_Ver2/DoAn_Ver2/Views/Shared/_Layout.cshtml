@using DoAn_Ver2.Models
@using DoAn_Ver2.Infrastructure

@{
    // 1. KHỞI TẠO GIÁ TRỊ MẶC ĐỊNH
    string siteLogo = "/Content/images/logo-default.png";
    string hotline = "1900 xxxx";
    string email = "contact@menstore.com";
    string address = "298 Minh Khai, Cầu Diễn, Hà Nội"; 
    string currentEffect = "none";
    try
    {
        // 2. LẤY CẤU HÌNH TỪ DB
        using (var uow = new UnitOfWork())
        {
            var repo = uow.Repository<CauHinhChung>();

            var confLogo = repo.GetById("SiteLogo");
            if (confLogo != null && !string.IsNullOrEmpty(confLogo.Value)) { siteLogo = confLogo.Value; }

            var confHotline = repo.GetById("Hotline");
            if (confHotline != null && !string.IsNullOrEmpty(confHotline.Value)) { hotline = confHotline.Value; }

            var confEmail = repo.GetById("Email");
            if (confEmail != null && !string.IsNullOrEmpty(confEmail.Value)) { email = confEmail.Value; }
            var confAddress = repo.GetById("FooterInfo");
            if (confAddress != null && !string.IsNullOrEmpty(confAddress.Value)) { address = confAddress.Value; }

            var effConfig = uow.Repository<CauHinhChung>().GetById("SiteEffect");
            if (effConfig != null) { currentEffect = effConfig.Value; }
        }
    }
    catch {  }
}


<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Men Store</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link href="~/Content/Site.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.theme.default.min.css">
    <link href="~/Content/main.css" rel="stylesheet" />
</head>
<body>
    <div id="toast-container"></div>

    <div class="header-top">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div class="left-info">
                    <span class="mr-3"><i class="fas fa-phone-alt"></i> Hotline: @hotline</span>
                    <span><i class="fas fa-envelope"></i> @email</span>
                </div>
                <div class="d-flex align-items-center right-links">
                    <form class="search-box-top mr-3" action="@Url.Action("Search", "Product")" method="get">
                        <input type="text" name="keyword" placeholder="Tìm kiếm..." />
                        <label for="realImageInput" class="btn-camera mb-0"><i class="fas fa-camera"></i></label>
                        <button type="submit"><i class="fas fa-search"></i></button>
                    </form>

                    <form id="imageSearchForm" action="@Url.Action("SearchByImage", "Product")" method="post" enctype="multipart/form-data" style="display:none;">
                        <input type="file" id="realImageInput" name="imageFile" accept="image/*" onchange="document.getElementById('imageSearchForm').submit();" />
                    </form>

                    @if (Session["KhachHang"] != null)
                    {
                        var kh = Session["KhachHang"] as DoAn_Ver2.Models.NguoiDung;
                        <span>Xin chào, <strong>@kh.HoTen</strong></span>
                        <a href="@Url.Action("Logout", "Account")">Đăng xuất</a>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")">Đăng nhập</a>
                        <span class="mx-1">/</span>
                        <a href="@Url.Action("Register", "Account")">Đăng ký</a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="main-header sticky-top">
        <div class="container">
            <nav class="navbar navbar-expand-lg navbar-light p-0">
                <a class="navbar-brand d-flex align-items-center font-weight-bold text-uppercase" href="/" style="font-size: 24px;">
                    <img src="@siteLogo" class="logo-img mr-2" style="max-height: 50px; width: auto;" alt="Men Store Logo" />
                    MEN<span class="text-primary">STORE</span>
                </a>


                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#mainMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainMenu">

                    @{ Html.RenderAction("_MenuPartial", "Home"); }

                    <div class="header-icons d-flex ml-auto">
                        <a href="@Url.Action("Index", "Profile")" class="icon-item" title="Thông tin cá nhân"><i class="far fa-user"></i></a>

                        <a href="@Url.Action("Index", "Order")" class="icon-item" title="Lịch sử đơn hàng"><i class="fas fa-box-open"></i></a>

                        @{ Html.RenderAction("_HeaderWishlist", "Wishlist"); }
                        @{ Html.RenderAction("_HeaderCart", "Home"); }

                    </div>
                </div>
            </nav>
        </div>
    </div>

    <div style="min-height: 600px;">
        @RenderBody()
    </div>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <h5 class="text-uppercase">Về chúng tôi</h5>
                    <p class="small">Men Store chuyên cung cấp các sản phẩm thời trang nam chất lượng cao, mẫu mã đa dạng và giá cả hợp lý.</p>
                    <div class="social-links mt-3">
                        <a href="#" class="d-inline mr-2"><i class="fab fa-facebook fa-lg"></i></a>
                        <a href="#" class="d-inline mr-2"><i class="fab fa-instagram fa-lg"></i></a>
                        <a href="#" class="d-inline"><i class="fab fa-youtube fa-lg"></i></a>
                    </div>
                </div>
                <div class="col-md-3">
                    <h5>Hỗ trợ khách hàng</h5>
                    <a href="#">Hướng dẫn mua hàng</a>
                    <a href="#">Chính sách đổi trả</a>
                    <a href="#">Chính sách bảo mật</a>
                    <a href="#">Tra cứu đơn hàng</a>
                </div>
                <div class="col-md-3">
                    <h5>Danh mục nổi bật</h5>
                    <a href="@Url.Action("ProductByCategory", "Product", new { id = 1 })">Áo Nam</a>
                    <a href="@Url.Action("ProductByCategory", "Product", new { id = 2 })">Quần Nam</a>
                    <a href="@Url.Action("ProductByCategory", "Product", new { id = 3 })">Phụ kiện</a>
                </div>
                <div class="col-md-3">
                    <h5>Liên hệ</h5>
                    <p class="small"><i class="fas fa-map-marker-alt"></i> @address</p>
                    <p class="small"><i class="fas fa-phone"></i> @hotline</p>
                    <p class="small"><i class="fas fa-envelope"></i> @email</p>
                </div>
            </div>
            <hr class="bg-secondary mt-4">
            <div class="text-center small">
                &copy; @DateTime.Now.Year NGUYỄN HUY CÔNG - ĐỒ ÁN TỐT NGHIỆP.
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>
    <script>
        document.getElementById('imgSearchInput').addEventListener('change', function () {
            if (this.files && this.files[0]) {
                var form = document.getElementById('searchForm');

                var formData = new FormData();
                formData.append("imageFile", this.files[0]);
                alert("Đang phân tích hình ảnh, vui lòng chờ...");

                // Gửi AJAX POST sang Action SearchByImage
                $.ajax({
                    url: '/Product/SearchByImage',
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (response) {
                        document.open();
                        document.write(response);
                        document.close();
                    },
                    error: function () {
                        alert('Lỗi tìm kiếm hình ảnh.');
                    }
                });
            }
        });
    </script>
    <script>
        // 1. Hàm hiển thị thông báo (Toast)
        function showToast(message, type) {
            var container = $('#toast-container');
            var iconClass = type === 'success' ? 'fa-check-circle' : 'fa-trash-alt';

            var toastHTML = ` <div class="custom-toast ${type}">
                                                            <i class="fas ${iconClass}"></i>
                                                            <span>${message}</span>
                                                            </div>`;

            var toast = $(toastHTML);
            container.append(toast);
            setTimeout(function () {
                toast.addClass('show');
            }, 100);

            // Tự tắt sau 3s
            setTimeout(function () {
                toast.removeClass('show');
                // Xóa khỏi DOM sau khi ẩn xong
                setTimeout(function () {
                    toast.remove();
                }, 500);
            }, 3000);
        }

        // 2. Hàm Toggle Wishlist
        function toggleWishlist(id, btn, isRemoveMode = false) {
            var icon = $(btn).find('i');

            $.post('/Wishlist/Toggle', { productId: id }, function (res) {
                if (res.success) {
                    $('#wishlistCountHeader').text(res.count);

                    if (isRemoveMode) {
                        $('#wish-item-' + id).fadeOut(300, function () {
                            $(this).remove();
                            if ($('.col-6').length === 0) location.reload();
                        });
                        showToast('Đã xóa khỏi danh sách yêu thích', 'danger');
                    } else {
                        if (res.isAdded) {
                            icon.removeClass('far').addClass('fas text-danger');
                            showToast('Đã thêm vào sản phẩm yêu thích', 'success');
                        } else {
                            icon.removeClass('fas text-danger').addClass('far');
                            showToast('Đã xóa khỏi danh sách yêu thích', 'danger');
                        }
                    }
                } else {
                    alert('Lỗi: ' + res.msg);
                }
            }).fail(function () {
                alert('Lỗi kết nối server! Vui lòng thử lại.');
            });
        }
    </script>




    @*================================================
        CHATBOT AI
        ================================================*@
    <button id="chatbot-toggle-btn" style="position: fixed; bottom: 20px; right: 20px; width: 60px; height: 60px; border-radius: 50%; background-color: #000; color: #fff; border: none; font-size: 24px; cursor: pointer; box-shadow: 0 4px 8px rgba(0,0,0,0.3); z-index: 9999; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;">
        <i class="fas fa-robot"></i>
    </button>

    <div id="chatbot-window" style="display: none; position: fixed; bottom: 90px; right: 20px; width: 350px; height: 450px; background-color: #fff; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.2); z-index: 9999; display: flex; flex-direction: column; overflow: hidden; border: 1px solid #ddd;">

        <div style="background-color: #000; color: #fff; padding: 15px; font-weight: bold; display: flex; justify-content: space-between; align-items: center;">
            <span><i class="fas fa-robot mr-2"></i> Trợ lý AI MenStore</span>
            <button id="chatbot-close-btn" style="background: none; border: none; color: #fff; font-size: 16px; cursor: pointer;">✖</button>
        </div>

        <div id="chatbot-messages" style="flex: 1; padding: 15px; overflow-y: auto; background-color: #f9f9f9; display: flex; flex-direction: column; gap: 10px;">
            <div style="align-self: flex-start; background-color: #e5e5ea; color: #000; padding: 10px 15px; border-radius: 15px; max-width: 80%; font-size: 14px;">
                Dạ em chào anh/chị, em là trợ lý AI của MEN STORE. Em có thể giúp cho anh/chị được ạ?
            </div>
        </div>

        <div style="padding: 10px; border-top: 1px solid #ddd; background-color: #fff; display: flex;">
            <input type="text" id="chatbot-input" placeholder="Nhập câu hỏi của bạn..." style="flex: 1; padding: 10px; border: 1px solid #ccc; border-radius: 20px; outline: none; font-size: 14px;">
            <button id="chatbot-send-btn" style="margin-left: 10px; background-color: #000; color: #fff; border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer;">➤</button>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            $('#chatbot-window').hide();

            $('#chatbot-toggle-btn').click(function () { $('#chatbot-window').toggle(); });
            $('#chatbot-close-btn').click(function () { $('#chatbot-window').hide(); });

            // =========================================================================
            // THUẬT TOÁN BỘ NHỚ TRÌNH DUYỆT (Giữ lịch sử xuyên suốt, tắt trình duyệt mới xóa)
            // =========================================================================

            // 1. Kiểm tra xem có Cookie đánh dấu phiên làm việc chưa
            if (document.cookie.indexOf("ai_session_active=true") === -1) {
                // Nếu chưa có (Nghĩa là khách vừa mới mở trình duyệt lên) -> Xóa sạch lịch sử cũ
                localStorage.removeItem('aiChatSession');

                // Tạo lại Cookie Session (Đặc tính của Cookie này là sẽ tự hủy khi khách tắt hẳn trình duyệt)
                document.cookie = "ai_session_active=true; path=/";
            }

            // 2. TẢI LỊCH SỬ CHAT TỪ LOCAL STORAGE (Dùng chung cho mọi Tab, mọi Trang)
            var chatHistory = JSON.parse(localStorage.getItem('aiChatSession')) || [];

            // In lại lịch sử cũ ra màn hình khi khách chuyển trang hoặc tải lại trang
            if (chatHistory.length > 0) {
                $('#chatbot-messages').empty(); // Xóa câu chào mặc định

                chatHistory.forEach(function (msg) {
                    if (msg.role === "user") {
                        $('#chatbot-messages').append('<div style="align-self: flex-end; background-color: #007bff; color: #fff; padding: 10px 15px; border-radius: 15px; max-width: 80%; font-size: 14px;">' + msg.text + '</div>');
                    } else if (msg.role === "model") {
                        var formattedReply = msg.text.replace(/\n/g, "<br>");
                        $('#chatbot-messages').append('<div style="align-self: flex-start; background-color: #e5e5ea; color: #000; padding: 10px 15px; border-radius: 15px; max-width: 80%; font-size: 14px;">' + formattedReply + '</div>');
                    }
                });
                $('#chatbot-messages').scrollTop($('#chatbot-messages')[0].scrollHeight);
            }

            // ===================
            // XỬ LÝ GỬI TIN NHẮN
            // ===================
            function sendMessage() {
                var msg = $('#chatbot-input').val().trim();
                if (msg === "") return;

                // In tin nhắn khách lên UI
                $('#chatbot-messages').append('<div style="align-self: flex-end; background-color: #007bff; color: #fff; padding: 10px 15px; border-radius: 15px; max-width: 80%; font-size: 14px;">' + msg + '</div>');
                $('#chatbot-input').val('');
                $('#chatbot-messages').scrollTop($('#chatbot-messages')[0].scrollHeight);

                // Hiện loading "Đang suy nghĩ..."
                var loadingId = "loading-" + Date.now();
                $('#chatbot-messages').append('<div id="' + loadingId + '" style="align-self: flex-start; background-color: #e5e5ea; color: #555; padding: 10px 15px; border-radius: 15px; max-width: 80%; font-size: 14px;"><i>Đang suy nghĩ...</i></div>');
                $('#chatbot-messages').scrollTop($('#chatbot-messages')[0].scrollHeight);

                // Gọi API lên Controller
                $.ajax({
                    url: '/Home/SendMessage',
                    type: 'POST',
                    data: {
                        userMessage: msg,
                        historyJson: JSON.stringify(chatHistory) // Gửi toàn bộ lịch sử lên cho AI đọc
                    },
                    success: function (response) {
                        $('#' + loadingId).remove(); // Xóa chữ loading
                        var formattedReply = response.reply.replace(/\n/g, "<br>");

                        // In câu trả lời AI lên UI
                        $('#chatbot-messages').append('<div style="align-self: flex-start; background-color: #e5e5ea; color: #000; padding: 10px 15px; border-radius: 15px; max-width: 80%; font-size: 14px;">' + formattedReply + '</div>');
                        $('#chatbot-messages').scrollTop($('#chatbot-messages')[0].scrollHeight);

                        // 3. LƯU LỊCH SỬ VÀO TRÍ NHỚ TRÌNH DUYỆT (LOCAL STORAGE)
                        chatHistory.push({ role: "user", text: msg });
                        chatHistory.push({ role: "model", text: response.reply });
                        localStorage.setItem('aiChatSession', JSON.stringify(chatHistory));
                    },
                    error: function () {
                        $('#' + loadingId).remove();
                        $('#chatbot-messages').append('<div style="align-self: flex-start; color: red; font-size: 14px;">Lỗi kết nối máy chủ AI.</div>');
                    }
                });
            }

            // Lắng nghe sự kiện click và gõ Enter
            $('#chatbot-send-btn').click(function () { sendMessage(); });
            $('#chatbot-input').keypress(function (e) { if (e.which == 13) sendMessage(); });
        });
    </script>


    @*================================================
        HIỆU ỨNG RƠI (Hoa, Tuyết, Điểm) + MƯA + PHÁO HOA
        ================================================*@
    <link href="~/Content/StyleHieuUng.css" rel="stylesheet" />
    <div id="ultimate-effect-container"></div>
    <script src="~/Scripts/HieuUng.js"></script>

    @RenderSection("scripts", required: false)

</body>
</html>