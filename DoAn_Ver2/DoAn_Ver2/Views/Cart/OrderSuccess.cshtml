@{
    var titleMain = ViewBag.TitleStatus ?? "ĐẶT HÀNG THÀNH CÔNG!";
    ViewBag.Title = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 text-center" style="min-height: 500px; display: flex; flex-direction: column; justify-content: center; align-items: center;">
    <div class="mb-4">
        <i class="fas fa-check-circle text-success" style="font-size: 90px;"></i>
    </div>
    <h2 class="font-weight-bold text-uppercase mb-3">@titleMain</h2>

    <p class="lead text-muted mb-4" style="max-width: 600px;">
        @(ViewBag.Msg ?? "Cảm ơn bạn đã mua hàng tại Men Store. Hệ thống đã ghi nhận đơn hàng và sẽ liên hệ sớm nhất để giao hàng cho bạn.")
    </p>

    <div class="d-flex">
        @if (ViewBag.TitleStatus != null)
        {
            <a href="@Url.Action("Index", "Order")" class="btn btn-dark btn-lg px-5 rounded-pill shadow-sm">
                <i class="fas fa-file-invoice mr-2"></i> Xem đơn hàng
            </a>
            <a href="/" class="btn btn-dark btn-lg px-5 rounded-pill shadow-sm">
                <i class="fas fa-arrow-left mr-2"></i> Tiếp tục mua sắm
            </a>
        }
        else
        {
            <a href="/" class="btn btn-dark btn-lg px-5 rounded-pill shadow-sm">
                <i class="fas fa-arrow-left mr-2"></i> Tiếp tục mua sắm
            </a>
        }
    </div>
</div>