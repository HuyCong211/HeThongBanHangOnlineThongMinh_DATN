@{
    ViewBag.Title = "Đặt hàng thất bại";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 text-center" style="min-height: 500px; display: flex; flex-direction: column; justify-content: center; align-items: center;">
    <div class="mb-4">
        <i class="fas fa-times-circle text-danger" style="font-size: 90px;"></i>
    </div>
    <h2 class="font-weight-bold text-uppercase mb-3 text-danger">Đặt hàng thất bại!</h2>

    <div class="alert alert-warning mb-4" style="max-width: 600px;">
        @(ViewBag.Msg ?? "Có lỗi xảy ra trong quá trình xử lý hoặc bạn đã hủy thanh toán.")
    </div>

    <div class="d-flex">
        <a href="@Url.Action("Index", "Cart")" class="btn btn-outline-secondary btn-lg mr-3 rounded-pill">
            <i class="fas fa-shopping-cart mr-2"></i> Xem lại giỏ hàng
        </a>
        <a href="/" class="btn btn-primary btn-lg rounded-pill shadow-sm">
            <i class="fas fa-home mr-2"></i> Về trang chủ
        </a>
    </div>
</div>