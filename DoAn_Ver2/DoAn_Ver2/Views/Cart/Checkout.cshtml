@model DoAn_Ver2.Models.ViewModel.CheckoutViewModel

@{
    ViewBag.Title = "Thanh toán";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selectedIds = ViewBag.SelectedIds as string;
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<style>
    /* Tùy chỉnh CSS cho Select2 đẹp hơn, khớp với Bootstrap */
    .select2-container .select2-selection--single {
        height: 38px !important; /* Chiều cao bằng input bootstrap */
        border: 1px solid #ced4da !important;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 36px !important;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 36px !important;
    }

    .select2-search__field {
        outline: none !important; /* Bỏ viền xanh khi focus */
    }
</style>


<div class="container pb-5">
    <form action="@Url.Action("Checkout", "Cart")" method="post" id="checkoutForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="selectedIds" value="@selectedIds" />

        <input type="hidden" name="MaVoucher" id="selectedVoucherCode" value="@Model.MaVoucher" />

        <div class="row">
            <div class="col-lg-7 mb-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white font-weight-bold text-uppercase py-3">
                        <i class="fas fa-map-marker-alt mr-2 text-danger"></i> Thông tin giao hàng
                    </div>
                    <div class="card-body">
                        @if (Model.SoDiaChi != null && Model.SoDiaChi.Count > 0)
                        {
                            <div class="form-group bg-light p-3 rounded border mb-4">
                                <label class="font-weight-bold text-primary mb-2">
                                    <i class="fas fa-address-book mr-2"></i>Chọn từ sổ địa chỉ:
                                </label>
                                <select class="form-control border-primary" id="addressBook" onchange="fillAddressFromBook()">
                                    <option value="">-- Nhập địa chỉ mới --</option>
                                    @foreach (var dc in Model.SoDiaChi)
                                    {
                                        <option value="@dc.ID"
                                                data-name="@dc.TenNguoiNhan"
                                                data-phone="@dc.SDT_NguoiNhan"
                                                data-detail="@dc.DiaChiChiTiet"
                                                data-province="@dc.Tinh_ThanhPho"
                                                data-ward="@dc.PhuongXa">
                                            @dc.TenNguoiNhan - @dc.SDT_NguoiNhan (@dc.DiaChiChiTiet, @dc.PhuongXa, @dc.Tinh_ThanhPho)
                                        </option>
                                    }
                                </select>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label>Họ tên người nhận <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(x => x.TenNguoiNhan, new { @class = "form-control", id = "inputName" })
                                @Html.ValidationMessageFor(x => x.TenNguoiNhan, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-6 form-group">
                                <label>Số điện thoại <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(x => x.SDT, new { @class = "form-control", id = "inputPhone" })
                                @Html.ValidationMessageFor(x => x.SDT, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-12 form-group">
                                <label>Email</label>
                                @Html.TextBoxFor(x => x.Email, new { @class = "form-control", id = "inputEmail" })
                                @Html.ValidationMessageFor(x => x.Email, "", new { @class = "text-danger small" })
                            </div>
                        </div>
                        <hr />
                        <div id="address-selection">
                            <div class="row">
                                <div class="col-md-6 form-group">
                                    <label>Tỉnh / Thành <span class="text-danger">*</span></label>
                                    <select name="TinhThanh" id="province" class="form-control select2-search">
                                        <option value="">-- Chọn Tỉnh/Thành --</option>
                                    </select>
                                    @Html.ValidationMessageFor(x => x.TinhThanh, "", new { @class = "text-danger small" })
                                </div>
                                <div class="col-md-6 form-group">
                                    <label>Phường / Xã <span class="text-danger">*</span></label>
                                    <select name="PhuongXa" id="ward" class="form-control select2-search" disabled>
                                        <option value="">-- Chọn Phường/Xã --</option>
                                    </select>
                                    @Html.ValidationMessageFor(x => x.PhuongXa, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                        </div>
                        <div id="address-display" style="display:none;" class="form-group bg-white border border-success rounded p-3 text-success">
                            <i class="fas fa-check-circle mr-1"></i> Sử dụng địa chỉ đã lưu: <br />
                            <strong id="savedAddressText"></strong>
                        </div>
                        <div class="form-group">
                            <label>Địa chỉ cụ thể <span class="text-danger">*</span></label>
                            @Html.TextBoxFor(x => x.DiaChiChiTiet, new { @class = "form-control", id = "inputDetail" })
                            @Html.ValidationMessageFor(x => x.DiaChiChiTiet, "", new { @class = "text-danger small" })
                        </div>
                        <div class="form-group">
                            <label>Ghi chú</label>
                            @Html.TextAreaFor(x => x.GhiChu, new { @class = "form-control", rows = 2 })
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card shadow-sm border-0 sticky-top" style="top: 20px; z-index: 1;">
                    <div class="card-header bg-dark text-white text-uppercase font-weight-bold py-3">
                        <i class="fas fa-shopping-cart mr-2"></i> Đơn hàng của bạn
                    </div>
                    <div class="card-body p-4">
                        <div class="checkout-product-list mb-3 pr-2" style="max-height: 300px; overflow-y: auto;">
                            <ul class="list-group list-group-flush">
                                @foreach (var item in Model.CartItems)
                                {
                                    <li class="list-group-item d-flex justify-content-between px-0 lh-condensed">
                                        <div style="width: 70%">
                                            <h6 class="my-0 small font-weight-bold">@item.TenSanPham</h6>
                                            <small class="text-muted">@item.TenPhanLoai x @item.SoLuong</small>
                                        </div>
                                        <span class="text-muted font-weight-bold">@item.ThanhTien.ToString("N0")đ</span>
                                    </li>
                                }
                            </ul>
                        </div>

                        <div class="mb-4">
                            <label class="font-weight-bold"><i class="fas fa-ticket-alt text-warning mr-2"></i>Mã giảm giá</label>

                            <div class="input-group mb-2">
                                <input type="text" class="form-control text-primary font-weight-bold bg-white" id="displayVoucherCode" placeholder="Chưa chọn mã nào" readonly value="@Model.MaVoucher">
                                <div class="input-group-append">
                                    <button class="btn btn-outline-primary" type="button" data-toggle="modal" data-target="#voucherModal">
                                        <i class="fas fa-list mr-1"></i> Chọn mã
                                    </button>
                                </div>
                            </div>

                            <div id="removeVoucherBlock" style="display: none;">
                                <button type="button" class="btn btn-sm btn-link text-danger p-0" id="btnRemoveVoucher">
                                    <i class="fas fa-times-circle"></i> Bỏ dùng voucher này
                                </button>
                            </div>
                        </div>

                        <ul class="list-group list-group-flush mb-4 border-top pt-3">
                            <li class="list-group-item d-flex justify-content-between px-0 py-1 border-0">
                                <span>Tạm tính</span>
                                <strong>@Model.TongTienHang.ToString("N0")đ</strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0 py-1 border-0">
                                <span>Phí vận chuyển</span>
                                <strong class="text-dark">@Model.PhiShip.ToString("N0")đ</strong>
                            </li>

                            <li class="list-group-item d-flex justify-content-between px-0 py-1 border-0 text-success" id="discountRow" style="display:none;">
                                <span><i class="fas fa-tag mr-1"></i>Voucher giảm giá</span>
                                <strong id="discountDisplay">-0đ</strong>
                            </li>

                            <li class="list-group-item d-flex justify-content-between px-0 py-3 border-top mt-2">
                                <span class="text-success font-weight-bold h5 mb-0">Tổng thanh toán</span>
                                <span class="text-danger h4 mb-0 font-weight-bold" id="totalDisplay">@((Model.TongTienHang + Model.PhiShip).ToString("N0"))đ</span>
                            </li>
                        </ul>

                        <h6 class="font-weight-bold mb-3 border-bottom pb-2">Phương thức thanh toán</h6>
                        <div class="payment-methods">
                            <div class="custom-control custom-radio mb-3 p-3 border rounded">
                                <input type="radio" id="cod" name="PhuongThucThanhToan" class="custom-control-input" value="1" checked>
                                <label class="custom-control-label font-weight-bold cursor-pointer" for="cod">
                                    <i class="fas fa-money-bill-wave text-success mr-2 fa-lg"></i> Thanh toán khi nhận hàng (COD)
                                </label>
                            </div>
                            <div class="custom-control custom-radio mb-3 p-3 border rounded">
                                <input type="radio" id="vnpay" name="PhuongThucThanhToan" class="custom-control-input" value="2">
                                <label class="custom-control-label font-weight-bold cursor-pointer" for="vnpay">
                                    <img src="https://cdn.haitrieu.com/wp-content/uploads/2022/10/Icon-VNPAY-QR.png" width="24" class="mr-2"> Thanh toán qua VNPay
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-danger btn-block btn-lg mt-4 font-weight-bold shadow-sm hover-up">
                            ĐẶT HÀNG NGAY <i class="fas fa-check ml-2"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="modal fade" id="voucherModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title font-weight-bold">Chọn MenStore Voucher</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body bg-light p-2" style="max-height: 400px; overflow-y: auto;">
                @if (Model.DsVoucherKhaDung != null && Model.DsVoucherKhaDung.Any())
                {
                    <div class="voucher-list">
                        @foreach (var voucher in Model.DsVoucherKhaDung)
                        {
                            // Tính toán logic hiển thị
                            decimal giaTriGiamThucTe = 0;
                            string textGiamGia = "";
                            string subText = "";

                            if (voucher.LoaiGiam == "PERCENT")
                            {
                                // Tính tiền thực tế (để JS dùng)
                                giaTriGiamThucTe = (Model.TongTienHang * (voucher.GiaTri ?? 0)) / 100;
                                textGiamGia = $"Giảm {voucher.GiaTri}%";
                                subText = $"Giảm tối đa {string.Format("{0:N0}", giaTriGiamThucTe)}đ";
                            }
                            else
                            {
                                giaTriGiamThucTe = voucher.GiaTri ?? 0;
                                textGiamGia = $"Giảm {voucher.GiaTri:N0}đ";
                            }

                            // Giới hạn max
                            if (giaTriGiamThucTe > Model.TongTienHang) { giaTriGiamThucTe = Model.TongTienHang; }

                            bool isBest = voucher == Model.DsVoucherKhaDung.First();

                            // LƯU Ý: Data attribute chỉ chứa số nguyên (Integer) để tránh lỗi JS float
                            long moneyInt = (long)giaTriGiamThucTe;

                            <div class="voucher-item card mb-2 border-0 shadow-sm"
                                 data-code="@voucher.MaCode"
                                 data-money="@moneyInt"
                                 style="cursor: pointer; transition: all 0.2s;">

                                <div class="card-body p-0 d-flex">
                                    <div class="bg-warning text-white p-3 d-flex flex-column justify-content-center align-items-center" style="width: 100px; min-width: 100px;">
                                        <i class="fas fa-gift fa-2x mb-1"></i>
                                        <span class="font-weight-bold small">CODE</span>
                                    </div>
                                    <div class="p-3 flex-grow-1 d-flex flex-column justify-content-center">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="font-weight-bold text-dark mb-1">@textGiamGia</h6>
                                                <div class="small text-muted mb-1">Đơn tối thiểu @string.Format("{0:N0}", voucher.DonToiThieu)đ</div>
                                                @if (!string.IsNullOrEmpty(subText) && voucher.LoaiGiam == "PERCENT")
                                                {
                                                    <div class="small text-muted font-italic">(@subText)</div>
                                                }
                                            </div>
                                            <div class="check-mark text-success d-none">
                                                <i class="fas fa-check-circle fa-lg"></i>
                                            </div>
                                        </div>
                                        <div class="mt-2 d-flex align-items-center">
                                            <span class="badge badge-light border text-secondary mr-2">@voucher.MaCode</span>
                                            @if (isBest)
                                            {<span class="badge badge-danger">Tốt nhất</span>}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-ticket-alt fa-3x text-muted mb-3"></i>
                        <p class="mb-0">Không có mã giảm giá nào phù hợp.</p>
                    </div>
                }
            </div>
            <div class="modal-footer bg-white">
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.21.1/axios.min.js"></script>
    <script src="~/Content/data/vietnam-regions.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            // 1. Kích hoạt Select2 cho các thẻ có class .select2-search
            $('.select2-search').select2({
                width: '100%', // Đảm bảo chiều rộng full ô
                placeholder: "-- Tìm kiếm --",
                allowClear: true
            });

            // 2. Logic đổ dữ liệu Tỉnh/Thành (Code cũ + Cập nhật Select2)
            const allCommunes = vietnamDataV2.communes;
            const provinceMap = new Map();
            allCommunes.forEach(item => { if (!provinceMap.has(item.provinceCode)) provinceMap.set(item.provinceCode, item.provinceName); });
            const sortedProvinces = Array.from(provinceMap).sort((a, b) => a[1].localeCompare(b[1]));

            sortedProvinces.forEach(([code, name]) => {
                $('#province').append(`<option value="${name}" data-code="${code}">${name}</option>`);
            });

            // [QUAN TRỌNG] Bắt sự kiện change của Select2
            $('#province').on('select2:select', function (e) {
                // Lấy data-code từ option đang chọn
                const selectedOption = $(this).find(':selected');
                const selectedProvinceCode = selectedOption.data('code');

                const $wardSelect = $('#ward');
                $wardSelect.empty().append('<option value="">-- Chọn Phường/Xã --</option>');

                if (selectedProvinceCode) {
                    const filteredWards = allCommunes.filter(c => c.provinceCode == selectedProvinceCode);
                    filteredWards.sort((a, b) => a.name.localeCompare(b.name));

                    filteredWards.forEach(w => {
                        $wardSelect.append(`<option value="${w.name}">${w.name}</option>`);
                    });

                    $wardSelect.prop('disabled', false);
                } else {
                    $wardSelect.prop('disabled', true);
                }

                // [CẬP NHẬT GIAO DIỆN SELECT2 SAU KHI ĐỔ DỮ LIỆU MỚI]
                // Nếu không có dòng này, danh sách xã sẽ không hiện ra trong ô tìm kiếm
                $wardSelect.trigger('change.select2');
            });

            // Xử lý khi xóa chọn tỉnh (nếu dùng allowClear)
            $('#province').on('select2:unselecting', function() {
                 $('#ward').empty().append('<option value="">-- Chọn Phường/Xã --</option>').prop('disabled', true).trigger('change');
            });
        });

        // 3. Hàm điền địa chỉ từ sổ (Cập nhật Select2)
        function fillAddressFromBook() {
            var opt = $('#addressBook').find(':selected');

            if (opt.val() === "") {
                $('#checkoutForm')[0].reset();
                $('#address-selection').show(); $('#address-display').hide();

                // Reset Select2 về trạng thái rỗng
                $('#province').val('').trigger('change').prop('disabled', false);
                $('#ward').empty().append('<option value="">-- Chọn Phường/Xã --</option>').trigger('change').prop('disabled', true);

                return;
            }

            $('#inputName').val(opt.data('name'));
            $('#inputPhone').val(opt.data('phone'));
            $('#inputDetail').val(opt.data('detail'));

            $('#address-selection').hide();
            $('#address-display').show();

            let fullText = `${opt.data('detail')}, ${opt.data('ward')}, ${opt.data('province')}`;
            $('#savedAddressText').text(fullText);

            // Gán giá trị cho Select2 (để khi submit form vẫn nhận được dữ liệu)
            // Lưu ý: Phải append option vào nếu nó chưa tồn tại (đề phòng select đang rỗng)
            var prov = opt.data('province');
            var ward = opt.data('ward');

            // Set Tỉnh
            if ($('#province option[value="' + prov + '"]').length == 0) {
                $('#province').append(new Option(prov, prov, true, true));
            }
            $('#province').val(prov).trigger('change');

            // Set Xã
            if ($('#ward option[value="' + ward + '"]').length == 0) {
                $('#ward').append(new Option(ward, ward, true, true));
            }
            $('#ward').val(ward).trigger('change');

            // Bỏ disable để submit được
            $('#province').prop('disabled', false);
            $('#ward').prop('disabled', false);
        }
        // --- 2. SCRIPT VOUCHER (ĐÃ FIX LỖI CLICK) ---
        // --- 2. SCRIPT VOUCHER (ĐÃ FIX LỖI RESET) ---
        $(document).ready(function() {
            // Lấy giá trị gốc từ Server (Chuyển sang Long để tránh lỗi format)
            var baseTotal = @((long)Model.TongTienHang);
            var shipFee = @((long)Model.PhiShip);

            // BẮT SỰ KIỆN CLICK VÀO VOUCHER
            $(document).on('click', '.voucher-item', function() {
                var self = $(this);
                var code = self.data('code');
                var discount = parseFloat(self.data('money'));

                // 1. Hiệu ứng UI trong Modal
                $('.voucher-item').removeClass('selected-voucher border-success').css('background-color', '#fff');
                $('.check-mark').addClass('d-none');

                self.addClass('selected-voucher border-success').css('background-color', '#f0fff4');
                self.find('.check-mark').removeClass('d-none');

                // 2. Cập nhật dữ liệu ra ngoài Form
                $('#selectedVoucherCode').val(code); // Quan trọng: Gán mã để gửi về Server
                $('#displayVoucherCode').val(code);  // Hiển thị cho user thấy
                $('#removeVoucherBlock').show();     // Hiện nút xóa

                // 3. Tính tiền hiển thị
                $('#discountDisplay').text('-' + discount.toLocaleString('vi-VN') + 'đ');
                $('#discountRow').show(); // Hiện dòng giảm giá

                var finalTotal = baseTotal + shipFee - discount;
                if(finalTotal < 0) finalTotal = 0;

                // Format tiền Việt Nam: 1.000.000đ
                $('#totalDisplay').text(finalTotal.toLocaleString('vi-VN') + 'đ');

                // 4. Đóng modal
                setTimeout(function(){
                    $('#voucherModal').modal('hide');
                }, 200);
            });

            // BẮT SỰ KIỆN NÚT BỎ CHỌN (FIX LỖI TẠI ĐÂY)
            $('#btnRemoveVoucher').click(function(e) {
                e.preventDefault(); // Ngăn chặn hành vi mặc định của button

                // 1. Xóa giá trị Input Hidden (Để Server không nhận được mã)
                $('#selectedVoucherCode').val('');
                $('#displayVoucherCode').val('');

                // 2. Ẩn nút xóa
                $('#removeVoucherBlock').hide();

                // 3. Reset UI Modal (Bỏ active các item)
                $('.voucher-item').removeClass('selected-voucher border-success').css('background-color', '#fff');
                $('.check-mark').addClass('d-none');

                // 4. Reset hiển thị Tiền
                $('#discountRow').hide(); // Ẩn dòng giảm giá đi
                $('#discountDisplay').text('-0đ'); // Reset text về 0

                // 5. Tính lại Tổng tiền (Về giá gốc)
                var finalTotal = baseTotal + shipFee;
                $('#totalDisplay').text(finalTotal.toLocaleString('vi-VN') + 'đ');
            });
        });
    </script>

    <style>
        .voucher-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
            border-color: #28a745 !important;
        }

        .selected-voucher {
            border: 2px solid #28a745 !important;
        }
    </style>
}