
@model IEnumerable<DoAn_Ver2.Models.DanhMuc>

<div class="vertical-menu">
    <div class="card-header bg-white font-weight-bold text-uppercase border-bottom text-primary pl-3">
        @ViewBag.TitleBlock
    </div>

    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            string activeClass = (Request.QueryString["id"] == item.ID.ToString()) ? "font-weight-bold text-primary bg-light" : "text-dark";

            <a href="@Url.Action("ProductByCategory", "Product", new { id = item.ID })"
               class="nav-link border-bottom py-2 pl-3 @activeClass" style="transition:0.3s;">
                <i class="fas fa-angle-right mr-2 small text-muted"></i> @item.TenDanhMuc
            </a>
        }
    }
    else
    {
        <div class="p-3 text-muted small font-italic">Đang cập nhật danh mục con...</div>
    }
</div>

<style>
    .vertical-menu .nav-link:hover {
        padding-left: 20px !important;
        color: #007bff !important;
        background: #f8f9fa;
    }
</style>